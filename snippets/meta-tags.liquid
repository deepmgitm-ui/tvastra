{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: shop.url
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_image = page_image
  if og_image == blank and request.page_type == 'product'
    assign og_image = product.featured_image
  endif
  if og_image == blank
    assign og_image = settings.logo
  endif
  assign og_image_url = ''
  if og_image != blank
    assign og_image_url = og_image | image_url: width: 1200 | prepend: 'https:'
  endif
  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'collection'
    assign og_type = 'product.group'
  elsif request.page_type == 'password'
    assign og_url = shop.url
  endif
-%}
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ og_url | escape }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | strip_html | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">
{%- if og_image_url != blank -%}
  <meta property="og:image" content="{{ og_image_url }}">
  <meta property="og:image:secure_url" content="{{ og_image_url }}">
  <meta property="og:image:width" content="{{ og_image.width | default: 1200 }}">
  <meta property="og:image:height" content="{{ og_image.height | default: 1200 }}">
  <meta property="og:image:alt" content="{{ og_title | escape }}">
{%- endif -%}
{%- if request.page_type == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html | escape }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' | escape }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | escape }}">
{%- if og_image_url != blank -%}
  <meta name="twitter:image" content="{{ og_image_url }}">
  <meta name="twitter:image:alt" content="{{ og_title | escape }}">
{%- endif -%}
