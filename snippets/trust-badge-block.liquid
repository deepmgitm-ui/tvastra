{%- if block_settings.trust_badge_text != blank or block_settings.trust_badge_img != blank -%}
  <div class="trust-badge product-trust-card d-flex align-items-{{ block_settings.text_alignment }} {{ block_settings.trust_badge_position }} ">
    <div class="product-trust-card__copy">
      <span class="product-trust-card__eyebrow">Verified checkout</span>
      <span class="product-trust-card__title">Trusted payments for every order</span>
    </div>
    <div class="product-trust-card__brand">
      {%- if block_settings.trust_badge_img != blank -%}
        <img src="{{ block_settings.trust_badge_img | image_url }}" alt="Trusted payment badge" width="{{ block_settings.trust_badge_img.width }}" height="{{ block_settings.trust_badge_img.height }}" loading="lazy" style="{% if block_settings.trust_badge_width != blank %}width: {{ block_settings.trust_badge_width }}px;{% endif %}" />
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'svg-placeholder position-static' }}
      {%- endif -%}
    </div>
    {%- if block_settings.trust_badge_text != blank -%}
      <div class="badge-test product-trust-card__note">{{ block_settings.trust_badge_text }}</div>
    {%- endif -%}
  </div>
{%- endif -%}
