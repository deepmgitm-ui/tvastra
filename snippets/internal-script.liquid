<!-- INTERNAL SCRIPTS -->
<script>  
  {%- capture variant_options_image -%} 
    {%- for i in (1..50) -%}
      {%- liquid 
        assign variant_option_parameter_name_key = 'variant_option_parameter_name' | append: i 
        assign variant_option_parameter_image_key = 'variant_option_parameter_image' | append: i
        assign variant_option_parameter_name = settings[variant_option_parameter_name_key]
        assign variant_option_parameter_image = settings[variant_option_parameter_image_key]
      -%}
      {%- if variant_option_parameter_name != '' and variant_option_parameter_image != null and variant_option_parameter_image != blank -%}
        {{- variant_option_parameter_name | json -}}: {{- variant_option_parameter_image | json -}},
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- assign variant_options_image = variant_options_image | strip_html | strip_newlines | strip -%}
  window.money_format = '{{ shop.money_format }}';
  window.routes = {
    shop_url: '{{ shop.url }}',
    root_url: '{{ routes.root_url }}',
    cart_url: '{{ routes.cart_url }}',
    cart_add_url: '{{ routes.cart_add_url }}',
    cart_change_url: '{{ routes.cart_change_url }}',
    cart_update_url: '{{ routes.cart_update_url }}'
  }
  window.cartStrings = {
    error: `{{ 'sections.cart.cart_error' | t }}`,
    quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t }}`
  }
  window.variantStrings = {
    addToCart: `<i class="feather-shopping-bag"></i><span>{{ 'products.product.add_to_cart' | t }}</span>`,
    preOrder: `<i class="feather-shopping-bag"></i><span>Pre-Order</span>`,
    addingToCart: 'Adding...',
    soldOut: `{{ 'products.product.sold_out' | t }}`,
    unavailable: `{{ 'products.product.unavailable' | t }}`,
  }
  window.wishlistStrings = {
    add: `{{ 'general.wishlist.add' | t }}`,
    remove: `{{ 'general.wishlist.remove' | t }}`
  }
  window.variantOptionsImage = { {{ variant_options_image }} };
  window.GOOGLE_MAP_API_KEY = '{{ settings.map_api_key }}';
  window.freeShippingConfig = {
    'enable': {% if settings.show_freeshipping_goal %}1{% else %}0{% endif %},
    'goal_amt': "{{ settings.freeshipping_goal_amount | times: 1 }}",
    'goal_amt_msg_1': "{{ settings.freeshipping_goal_msg_1 }}",
    'goal_amt_msg_2': "{{ settings.freeshipping_goal_msg_2 }}",
    'cart_total': "{{ cart.total_price }}",
    'template': "{{ template }}"
  }
  (function(){
    function fixMobileProductThumbs(){
      if(window.innerWidth>767)return;
      document.querySelectorAll('.product-gallery .product-image-main').forEach(function(mainEl){
        var mainSwiper=mainEl.swiper;
        var gallery=mainEl.closest('.product-gallery');
        var thumbEl=gallery&&gallery.querySelector('.product-image-thumb');
        var thumbSwiper=thumbEl&&thumbEl.swiper;
        if(!mainSwiper||!thumbSwiper||thumbEl.dataset.mobileThumbFreeScroll==='true')return;
        thumbEl.dataset.mobileThumbFreeScroll='true';
        if(mainSwiper.thumbs){mainSwiper.thumbs.swiper=null;}
        thumbSwiper.params.freeMode=thumbSwiper.params.freeMode||{};
        thumbSwiper.params.freeMode.enabled=true;
        thumbSwiper.params.freeMode.sticky=false;
        thumbSwiper.params.slidesPerView='auto';
        thumbSwiper.params.spaceBetween=10;
        thumbSwiper.params.centeredSlides=false;
        if(thumbSwiper.changeDirection){thumbSwiper.changeDirection('horizontal');}
        thumbSwiper.update();
        function updateActiveThumb(){
          var activeIndex=typeof mainSwiper.realIndex==='number'?mainSwiper.realIndex:mainSwiper.activeIndex;
          thumbEl.querySelectorAll('.swiper-slide').forEach(function(slide,index){
            slide.classList.toggle('swiper-slide-thumb-active',index===activeIndex);
          });
        }
        thumbEl.addEventListener('click',function(event){
          var slide=event.target.closest('.swiper-slide');
          if(!slide||!thumbEl.contains(slide))return;
          var slides=Array.prototype.slice.call(thumbEl.querySelectorAll('.swiper-slide'));
          var index=slides.indexOf(slide);
          if(index>=0){mainSwiper.slideTo(index);}
        });
        mainSwiper.on('slideChange',updateActiveThumb);
        updateActiveThumb();
      });
    }
    document.addEventListener('DOMContentLoaded',function(){setTimeout(fixMobileProductThumbs,600);});
    document.addEventListener('shopify:section:load',function(){setTimeout(fixMobileProductThumbs,600);});
    window.addEventListener('resize',function(){setTimeout(fixMobileProductThumbs,200);});
  })();
  (function(){
    function setupCollectionLoadMore(){
      if(document.documentElement.dataset.collectionLoadMoreBound==='true')return;
      document.documentElement.dataset.collectionLoadMoreBound='true';
      document.addEventListener('click',function(event){
        var link=event.target.closest('#load-more-btn a');
        var grid=document.querySelector('#main-collection-product-grid');
        if(!link||!grid||grid.dataset.loadingMore==='true')return;
        event.preventDefault();
        event.stopImmediatePropagation();
        grid.dataset.loadingMore='true';
        link.setAttribute('aria-busy','true');
        link.classList.add('loading');
        fetch(link.href,{credentials:'same-origin'})
          .then(function(response){
            if(!response.ok)throw new Error('Unable to load more products');
            return response.text();
          })
          .then(function(markup){
            var page=new DOMParser().parseFromString(markup,'text/html');
            var nextGrid=page.querySelector('#main-collection-product-grid');
            if(!nextGrid)throw new Error('Product grid was not found');
            grid.insertAdjacentHTML('beforeend',nextGrid.innerHTML);
            var currentButton=document.querySelector('#load-more-btn');
            var nextButton=page.querySelector('#load-more-btn');
            if(currentButton&&nextButton&&nextButton.querySelector('a')){
              currentButton.replaceWith(nextButton.cloneNode(true));
            }else if(currentButton){
              currentButton.remove();
            }
            var currentCount=document.querySelector('.pegi-product-count');
            var nextCount=page.querySelector('.pegi-product-count');
            if(currentCount&&nextCount){
              currentCount.innerHTML=nextCount.innerHTML;
              currentCount.setAttribute('current-item',nextCount.getAttribute('current-item')||'');
              currentCount.setAttribute('total-item',nextCount.getAttribute('total-item')||'');
            }
            var currentProgress=document.querySelector('.progress-percent');
            var shown=parseInt(nextCount&&nextCount.getAttribute('current-item'),10);
            var total=parseInt(nextCount&&nextCount.getAttribute('total-item'),10);
            if(currentProgress&&shown&&total){
              var percent=Math.min(100,Math.round(shown*100/total));
              currentProgress.style.width=percent+'%';
              currentProgress.setAttribute('data-percent',percent);
            }
            if(window.initSwatchOptionImage)window.initSwatchOptionImage();
            if(window.initVariantChanger)window.initVariantChanger(grid);
            if(window.initTooltips)window.initTooltips(grid.querySelectorAll('[data-bs-toggle="tooltip"]'));
            document.dispatchEvent(new CustomEvent('initialize:wishlist-button'));
          })
          .catch(function(){
            link.removeAttribute('aria-busy');
            link.classList.remove('loading');
          })
          .finally(function(){delete grid.dataset.loadingMore;});
      },true);
    }
    document.addEventListener('DOMContentLoaded',setupCollectionLoadMore);
    document.addEventListener('shopify:section:load',setupCollectionLoadMore);
  })();
  {{ settings.custom_js }}
</script>
<!-- END -->
{%- comment -%} If cart has only gift wrap item then remove it. {%- endcomment -%}
{%- liquid
  assign giftwraps_in_cart = 0
  if settings.enable_giftwrap
    assign giftwrap_product = all_products[settings.giftwrap_product]
    assign giftwrap_product_id = giftwrap_product.selected_or_first_available_variant.id
    for item in cart.items
      if item.id == giftwrap_product_id
        assign giftwraps_in_cart = item.quantity
      endif
    endfor
    if giftwraps_in_cart > 0 and cart.items.size == 1
    endif
  endif
-%}
<script type="text/javascript">
  Shopify.GiftWrap = Shopify.GiftWrap || {};
  Shopify.GiftWrap.enabled = {{ settings.enable_giftwrap }};
  Shopify.GiftWrap.product = '{{ settings.giftwrap_product }}';
  Shopify.GiftWrap.checkbox_label = '{{ settings.checkbox_label }}';
</script>
