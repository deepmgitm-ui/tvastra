{%- if settings.custom_style != blank -%}
  <style>
    {{- settings.custom_style -}}
  </style>
{%- endif -%}

<style>
  @media (max-width: 767px) {
    .main-product-page .product-gallery .product-main-slider {
      width: 100% !important;
      order: 1 !important;
    }

    .main-product-page .product-gallery .product-thumb-wrap {
      position: static !important;
      bottom: auto !important;
      left: auto !important;
      transform: none !important;
      width: 100% !important;
      max-width: none !important;
      margin: 12px 0 0 !important;
      padding: 0 14px !important;
      order: 2 !important;
      overflow: hidden !important;
    }

    .main-product-page .product-gallery .product-thumb-wrap .product-image-thumb {
      width: 100% !important;
      max-height: none !important;
      margin-top: 0 !important;
      overflow: visible !important;
