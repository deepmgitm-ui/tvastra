{%- liquid
  assign _p = product
  assign _siblings = _p.metafields.custom.sibling_products.value
  assign _hex = _p.metafields.custom.swatch_color.value
  assign _name = _p.metafields.custom.swatch_name.value

  assign _show = false
  if _hex != blank
    assign _show = true
  endif
  if _siblings != blank and _siblings.size > 0
    assign _show = true
  endif
-%}

{%- if _show -%}

  {%- if is_product_page == true -%}
    {%- comment -%} ==== PRODUCT PAGE VIEW (CAPSULE / PILLS WITH TEXT) ==== {%- endcomment -%}
    <div style="margin-bottom: 20px; margin-top: 10px;">
      <div style="font-size: 14px; font-weight: 600; color: #000; margin-bottom: 10px;">
        Colour: <span style="font-weight: 400; color: #555; text-transform: capitalize;">{{ _name }}</span>
      </div>
      
      <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        {%- comment -%} CURRENT PRODUCT (ACTIVE PILL) {%- endcomment -%}
        {%- if _hex != blank -%}
          <a href="{{ _p.url }}" style="display: inline-flex; align-items: center; gap: 8px; padding: 4px 14px 4px 4px; border: 1px solid #000; border-radius: 40px; text-decoration: none; background: #f9f9f9; box-shadow: inset 0 0 0 1px #000; cursor: default;" title="{{ _name }}">
            <span style="width: 24px; height: 24px; border-radius: 50%; display: block; background-color: {{ _hex }}; border: 1px solid rgba(0,0,0,0.15); flex-shrink: 0;"></span>
            <span style="font-size: 13px; font-weight: 700; color: #000; text-transform: capitalize; line-height: 1; padding-bottom: 1px;">{{ _name }}</span>
          </a>
        {%- endif -%}

        {%- comment -%} SIBLING PRODUCTS (CLICKABLE PILLS) {%- endcomment -%}
        {%- for s in _siblings -%}
          {%- if s.handle == _p.handle -%}{%- continue -%}{%- endif -%}
          {%- assign _sh = s.metafields.custom.swatch_color.value -%}
          {%- assign _sn = s.metafields.custom.swatch_name.value -%}
          {%- if _sh != blank -%}
            <a href="{{ s.url }}" style="display: inline-flex; align-items: center; gap: 8px; padding: 4px 14px 4px 4px; border: 1px solid #ddd; border-radius: 40px; text-decoration: none; background: #fff; transition: border-color 0.2s ease;" title="{{ _sn }}" onmouseover="this.style.borderColor='#999';" onmouseout="this.style.borderColor='#ddd';">
              <span style="width: 24px; height: 24px; border-radius: 50%; display: block; background-color: {{ _sh }}; border: 1px solid rgba(0,0,0,0.15); flex-shrink: 0;"></span>
              <span style="font-size: 13px; font-weight: 500; color: #333; text-transform: capitalize; line-height: 1; padding-bottom: 1px;">{{ _sn }}</span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  {%- else -%}
    {%- comment -%} ==== COLLECTION CARD VIEW (SMALL CIRCLE DOTS EXACTLY LIKE PICTURE 1) ==== {%- endcomment -%}
    <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; align-items: center;">
      
      {%- comment -%} CURRENT PRODUCT (ACTIVE DOT WITH OUTER RING) {%- endcomment -%}
      {%- if _hex != blank -%}
        <a href="{{ _p.url }}" style="display: flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; border: 1px solid #000; padding: 2px; cursor: pointer; background: transparent;" title="{{ _name }}">
          <span style="display: block; width: 100%; height: 100%; border-radius: 50%; background-color: {{ _hex }}; border: 1px solid rgba(0,0,0,0.1);"></span>
        </a>
      {%- endif -%}

      {%- comment -%} SIBLING PRODUCTS (INACTIVE DOTS) {%- endcomment -%}
      {%- for s in _siblings -%}
        {%- if s.handle == _p.handle -%}{%- continue -%}{%- endif -%}
        {%- assign _sh = s.metafields.custom.swatch_color.value -%}
        {%- assign _sn = s.metafields.custom.swatch_name.value -%}
        {%- if _sh != blank -%}
          <a href="{{ s.url }}" style="display: flex; align-items: center; justify-content: center; width: 22px; height: 22px; border-radius: 50%; border: 1px solid transparent; padding: 2px; transition: border-color 0.2s; background: transparent;" title="{{ _sn }}" onmouseover="this.style.borderColor='#999';" onmouseout="this.style.borderColor='transparent';">
            <span style="display: block; width: 100%; height: 100%; border-radius: 50%; background-color: {{ _sh }}; border: 1px solid rgba(0,0,0,0.1);"></span>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  {%- endif -%}

{%- endif -%}