{% doc %}
  @prompt
    need a copy section of slideshow 1 but with 2 buttons in a single row in small size and a small size title in white color make it the section covers the header as well in transparent header mode and the height should be fit the screen \
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fullscreen-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    display: block;
  }

  .ai-fullscreen-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-fullscreen-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}ms ease-in-out;
    pointer-events: none;
  }

  .ai-fullscreen-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-fullscreen-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-fullscreen-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-fullscreen-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-fullscreen-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-fullscreen-slide-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-fullscreen-slide-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    margin: 0 0 30px;
    font-weight: 500;
  }

  .ai-fullscreen-slide-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-fullscreen-slide-button-{{ ai_gen_id }} {
    padding: 10px 25px;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    display: inline-block;
    cursor: pointer;
    border: {{ block.settings.button_border_width }}px solid;
  }

  .ai-fullscreen-slide-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text }};
    border-color: {{ block.settings.button_primary_border }};
  }

  .ai-fullscreen-slide-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_text }};
    border-color: {{ block.settings.button_primary_hover_border }};
  }

  .ai-fullscreen-slide-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-fullscreen-slide-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_text }};
    border-color: {{ block.settings.button_secondary_hover_border }};
  }

  .ai-fullscreen-slide-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: {{ block.settings.nav_opacity }};
  }

  .ai-fullscreen-slide-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    color: {{ block.settings.nav_hover_icon_color }};
    opacity: 1;
  }

  .ai-fullscreen-slide-nav-prev-{{ ai_gen_id }} {
    left: 30px;
  }

  .ai-fullscreen-slide-nav-next-{{ ai_gen_id }} {
    right: 30px;
  }

  .ai-fullscreen-slide-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-fullscreen-slide-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: {{ block.settings.dot_opacity }};
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    padding: 0;
  }

  .ai-fullscreen-slide-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-fullscreen-slide-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.6 }}px;
      margin-bottom: 20px;
    }

    .ai-fullscreen-slide-button-{{ ai_gen_id }} {
      padding: 8px 20px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }

    .ai-fullscreen-slide-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-fullscreen-slide-nav-prev-{{ ai_gen_id }} {
      left: 15px;
    }

    .ai-fullscreen-slide-nav-next-{{ ai_gen_id }} {
      right: 15px;
    }
  }
{% endstyle %}

<fullscreen-slideshow-{{ ai_gen_id }}
  class="ai-fullscreen-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-fullscreen-slideshow-container-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_title_key = 'slide_' | append: i | append: '_title'
        assign slide_button1_text_key = 'slide_' | append: i | append: '_button1_text'
        assign slide_button1_link_key = 'slide_' | append: i | append: '_button1_link'
        assign slide_button2_text_key = 'slide_' | append: i | append: '_button2_text'
        assign slide_button2_link_key = 'slide_' | append: i | append: '_button2_link'

        assign slide_image = block.settings[slide_image_key]
        assign slide_title = block.settings[slide_title_key]
        assign slide_button1_text = block.settings[slide_button1_text_key]
        assign slide_button1_link = block.settings[slide_button1_link_key]
        assign slide_button2_text = block.settings[slide_button2_text_key]
        assign slide_button2_link = block.settings[slide_button2_link_key]
      %}

      <div
        class="ai-fullscreen-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
        data-slide-index="{{ forloop.index0 }}"
      >
        {% if slide_image %}
          <img
            src="{{ slide_image | image_url: width: 2000 }}"
            srcset="{{ slide_image | image_url: width: 750 }} 750w, {{ slide_image | image_url: width: 1500 }} 1500w, {{ slide_image | image_url: width: 2000 }} 2000w"
            sizes="100vw"
            alt="{{ slide_image.alt | escape }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            class="ai-fullscreen-slide-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-fullscreen-slide-placeholder-{{ ai_gen_id }}">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        <div class="ai-fullscreen-slide-overlay-{{ ai_gen_id }}"></div>

        <div class="ai-fullscreen-slide-content-{{ ai_gen_id }}">
          {% if slide_title != blank %}
            <h2 class="ai-fullscreen-slide-title-{{ ai_gen_id }}">{{ slide_title }}</h2>
          {% endif %}

          {% if slide_button1_text != blank or slide_button2_text != blank %}
            <div class="ai-fullscreen-slide-buttons-{{ ai_gen_id }}">
              {% if slide_button1_text != blank %}
                <a
                  href="{{ slide_button1_link | default: '#' }}"
                  class="ai-fullscreen-slide-button-{{ ai_gen_id }} ai-fullscreen-slide-button-primary-{{ ai_gen_id }}"
                >
                  {{ slide_button1_text }}
                </a>
              {% endif %}

              {% if slide_button2_text != blank %}
                <a
                  href="{{ slide_button2_link | default: '#' }}"
                  class="ai-fullscreen-slide-button-{{ ai_gen_id }} ai-fullscreen-slide-button-secondary-{{ ai_gen_id }}"
                >
                  {{ slide_button2_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}

    {% if block.settings.show_navigation %}
      <button
        class="ai-fullscreen-slide-nav-{{ ai_gen_id }} ai-fullscreen-slide-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-fullscreen-slide-nav-{{ ai_gen_id }} ai-fullscreen-slide-nav-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-fullscreen-slide-dots-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          <button
            class="ai-fullscreen-slide-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
            aria-label="Go to slide {{ forloop.index }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</fullscreen-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class FullscreenSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-fullscreen-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-fullscreen-slide-dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-fullscreen-slide-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-fullscreen-slide-nav-next-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5000;

        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('fullscreen-slideshow-{{ ai_gen_id }}', FullscreenSlideshow{{ ai_gen_id }});
  })();
</script>

