{% doc %}
  @prompt
    make wishlist product grid with a separate product card settings
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-wishlist-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-wishlist-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-wishlist-grid__card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-wishlist-grid__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-wishlist-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-wishlist-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-wishlist-grid__remove-btn-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.remove_btn_spacing }}px;
    right: {{ block.settings.remove_btn_spacing }}px;
    width: {{ block.settings.remove_btn_size }}px;
    height: {{ block.settings.remove_btn_size }}px;
    background-color: {{ block.settings.remove_btn_bg }};
    color: {{ block.settings.remove_btn_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 2;
    opacity: {{ block.settings.remove_btn_opacity }};
  }

  .ai-wishlist-grid__remove-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.remove_btn_hover_bg }};
    color: {{ block.settings.remove_btn_hover_color }};
    opacity: 1;
    transform: scale(1.1);
  }

  .ai-wishlist-grid__remove-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.remove_btn_size }}px * 0.5);
    height: calc({{ block.settings.remove_btn_size }}px * 0.5);
  }

  .ai-wishlist-grid__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_spacing }}px;
    left: {{ block.settings.badge_spacing }}px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 10px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 1;
  }

  .ai-wishlist-grid__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-wishlist-grid__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_font_size }}px;
    color: {{ block.settings.vendor_color }};
    margin-bottom: 6px;
    text-transform: {{ block.settings.vendor_text_transform }};
  }

  .ai-wishlist-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .ai-wishlist-grid__title-link-{{ ai_gen_id }} {
    color: inherit;
    text-decoration: none;
  }

  .ai-wishlist-grid__title-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.title_hover_color }};
  }

  .ai-wishlist-grid__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-wishlist-grid__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-wishlist-grid__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-wishlist-grid__add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-wishlist-grid__add-to-cart-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-wishlist-grid__add-to-cart-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-wishlist-grid__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.empty_text_color }};
  }

  .ai-wishlist-grid__empty-icon-{{ ai_gen_id }} {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    opacity: 0.3;
  }

  .ai-wishlist-grid__empty-title-{{ ai_gen_id }} {
    font-size: 24px;
    margin: 0 0 10px;
  }

  .ai-wishlist-grid__empty-text-{{ ai_gen_id }} {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-wishlist-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-wishlist-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-wishlist-grid__content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<wishlist-grid-{{ ai_gen_id }} class="ai-wishlist-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_heading and block.settings.heading != blank %}
    <h2 style="text-align: {{ block.settings.heading_alignment }}; margin-bottom: 30px; color: {{ block.settings.heading_color }};">
      {{ block.settings.heading }}
    </h2>
  {% endif %}

  <div class="ai-wishlist-grid__container-{{ ai_gen_id }}" data-wishlist-container>
  </div>

  <div class="ai-wishlist-grid__empty-{{ ai_gen_id }}" data-empty-state style="display: none;">
    <svg class="ai-wishlist-grid__empty-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <h3 class="ai-wishlist-grid__empty-title-{{ ai_gen_id }}">{{ block.settings.empty_heading }}</h3>
    <p class="ai-wishlist-grid__empty-text-{{ ai_gen_id }}">{{ block.settings.empty_text }}</p>
  </div>
</wishlist-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class WishlistGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.container = this.querySelector('[data-wishlist-container]');
        this.emptyState = this.querySelector('[data-empty-state]');
        this.showSaleBadge = {{ block.settings.show_sale_badge }};
        this.showSoldOutBadge = {{ block.settings.show_sold_out_badge }};
        this.showVendor = {{ block.settings.show_vendor }};
        this.showPrice = {{ block.settings.show_price }};
        this.showAddToCart = {{ block.settings.show_add_to_cart }};
      }

      connectedCallback() {
        this.loadWishlist();
      }

      loadWishlist() {
        const wishlistData = this.getWishlistFromStorage();
        
        if (wishlistData.length === 0) {
          this.showEmptyState();
          return;
        }

        this.fetchProductData(wishlistData);
      }

      getWishlistFromStorage() {
        try {
          const wishlist = localStorage.getItem('wishlist');
          return wishlist ? JSON.parse(wishlist) : [];
        } catch (e) {
          return [];
        }
      }

      async fetchProductData(productHandles) {
        this.container.innerHTML = '';
        
        for (const handle of productHandles) {
          try {
            const response = await fetch(`/products/${handle}.js`);
            const product = await response.json();
            this.renderProductCard(product);
          } catch (error) {
            console.error('Error fetching product:', error);
          }
        }
      }

      renderProductCard(product) {
        const card = document.createElement('div');
        card.className = 'ai-wishlist-grid__card-{{ ai_gen_id }}';
        
        const imageUrl = product.featured_image || '';
        const price = this.formatMoney(product.price);
        const comparePrice = product.compare_at_price > product.price ? this.formatMoney(product.compare_at_price) : '';
        const isOnSale = product.compare_at_price > product.price;
        const isSoldOut = !product.available;

        let badgeHTML = '';
        if (this.showSaleBadge && isOnSale) {
          badgeHTML = `<span class="ai-wishlist-grid__badge-{{ ai_gen_id }}">{{ block.settings.sale_badge_text }}</span>`;
        } else if (this.showSoldOutBadge && isSoldOut) {
          badgeHTML = `<span class="ai-wishlist-grid__badge-{{ ai_gen_id }}">{{ block.settings.sold_out_badge_text }}</span>`;
        }

        let vendorHTML = '';
        if (this.showVendor && product.vendor) {
          vendorHTML = `<div class="ai-wishlist-grid__vendor-{{ ai_gen_id }}">${product.vendor}</div>`;
        }

        let priceHTML = '';
        if (this.showPrice) {
          priceHTML = `
            <div class="ai-wishlist-grid__price-wrapper-{{ ai_gen_id }}">
              <span class="ai-wishlist-grid__price-{{ ai_gen_id }}">${price}</span>
              ${comparePrice ? `<span class="ai-wishlist-grid__compare-price-{{ ai_gen_id }}">${comparePrice}</span>` : ''}
            </div>
          `;
        }

        let buttonHTML = '';
        if (this.showAddToCart) {
          buttonHTML = `
            <button class="ai-wishlist-grid__add-to-cart-{{ ai_gen_id }}" data-add-to-cart="${product.variants[0].id}" ${isSoldOut ? 'disabled' : ''}>
              ${isSoldOut ? '{{ block.settings.sold_out_button_text }}' : '{{ block.settings.add_to_cart_text }}'}
            </button>
          `;
        }

        card.innerHTML = `
          <div class="ai-wishlist-grid__image-wrapper-{{ ai_gen_id }}">
            ${imageUrl ? `<img src="${imageUrl}" alt="${this.escapeHtml(product.title)}" class="ai-wishlist-grid__image-{{ ai_gen_id }}" loading="lazy">` : ''}
            <button class="ai-wishlist-grid__remove-btn-{{ ai_gen_id }}" data-remove-wishlist="${product.handle}" aria-label="Remove from wishlist">
              <svg class="ai-wishlist-grid__remove-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
            ${badgeHTML}
          </div>
          <div class="ai-wishlist-grid__content-{{ ai_gen_id }}">
            ${vendorHTML}
            <h3 class="ai-wishlist-grid__title-{{ ai_gen_id }}">
              <a href="${product.url}" class="ai-wishlist-grid__title-link-{{ ai_gen_id }}">${this.escapeHtml(product.title)}</a>
            </h3>
            ${priceHTML}
            ${buttonHTML}
          </div>
        `;

        this.container.appendChild(card);
      }

      showEmptyState() {
        this.container.style.display = 'none';
        this.emptyState.style.display = 'block';
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }

      formatMoney(cents) {
        const amount = (cents / 100).toFixed(2);
        return `{{ cart.currency.symbol }}${amount}`;
      }
    }

    customElements.define('wishlist-grid-{{ ai_gen_id }}', WishlistGrid{{ ai_gen_id }});

    document.addEventListener('click', function(e) {
      if (e.target.closest('[data-remove-wishlist]')) {
        const handle = e.target.closest('[data-remove-wishlist]').dataset.removeWishlist;
        removeFromWishlist{{ ai_gen_id }}(handle);
      }

      if (e.target.closest('[data-add-to-cart]')) {
        const variantId = e.target.closest('[data-add-to-cart]').dataset.addToCart;
        addToCart{{ ai_gen_id }}(variantId, e.target.closest('[data-add-to-cart]'));
      }
    });

    function removeFromWishlist{{ ai_gen_id }}(handle) {
      try {
        let wishlist = JSON.parse(localStorage.getItem('wishlist') || '[]');
        wishlist = wishlist.filter(item => item !== handle);
        localStorage.setItem('wishlist', JSON.stringify(wishlist));
        
        const grid = document.querySelector('wishlist-grid-{{ ai_gen_id }}');
        if (grid) {
          grid.loadWishlist();
        }
      } catch (e) {
        console.error('Error removing from wishlist:', e);
      }
    }

    async function addToCart{{ ai_gen_id }}(variantId, button) {
      const originalText = button.textContent;
      button.textContent = '{{ block.settings.adding_text }}';
      button.disabled = true;

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        });

        if (response.ok) {
          button.textContent = '{{ block.settings.added_text }}';
          setTimeout(function() {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
          
          if (window.theme && window.theme.cart) {
            window.theme.cart.refresh();
          }
        } else {
          throw new Error('Failed to add to cart');
        }
      } catch (error) {
        button.textContent = originalText;
        button.disabled = false;
        console.error('Error adding to cart:', error);
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Wishlist product grid",
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#262626"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
