      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_padding_bottom",
      "label": "Bottom padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_padding_left",
      "label": "Left padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_padding_right",
      "label": "Right padding",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background color",
