{% doc %}
  @prompt
    make a creative slide section for collection sliders 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-slider-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-collection-slider-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
    padding: 0 20px;
  }

  .ai-collection-slider-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
  }

  .ai-collection-slider-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-collection-slider-container-{{ ai_gen_id }} {
    position: relative;
    padding: 0 60px;
  }

  .ai-collection-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-collection-slider-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-collection-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.slides_per_view }} - 1) * {{ block.settings.slide_gap }}px) / {{ block.settings.slides_per_view }});
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-collection-slide-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.15);
  }

  .ai-collection-slide-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-collection-slide-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-collection-slide-{{ ai_gen_id }}:hover .ai-collection-slide-image-{{ ai_gen_id }} {
    transform: scale(1.1);
  }

  .ai-collection-slide-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: {{ block.settings.content_padding }}px;
    transition: opacity 0.3s ease;
  }

  .ai-collection-slide-content-{{ ai_gen_id }} {
    color: {{ block.settings.card_text_color }};
  }

  .ai-collection-slide-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.card_text_color }};
  }

  .ai-collection-slide-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_count_size }}px;
    margin: 0 0 12px;
    opacity: 0.9;
    color: {{ block.settings.card_text_color }};
  }

  .ai-collection-slide-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_bg_color }};
  }

  .ai-collection-slide-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-collection-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .ai-collection-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    color: {{ block.settings.nav_hover_icon_color }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-collection-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-collection-slider-nav-{{ ai_gen_id }}:disabled:hover {
    transform: translateY(-50%) scale(1);
  }

  .ai-collection-slider-nav-prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-collection-slider-nav-next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-collection-slider-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
    padding: 0 20px;
  }

  .ai-collection-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-collection-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    width: 30px;
    border-radius: 5px;
  }

  .ai-collection-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-collection-empty-state-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - (2 * {{ block.settings.slide_gap }}px)) / 3);
    }

    .ai-collection-slider-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-collection-slider-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-slide-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.slide_gap }}px) / 2);
    }

    .ai-collection-slider-container-{{ ai_gen_id }} {
      padding: 0 50px;
    }

    .ai-collection-slider-nav-{{ ai_gen_id }} {
      width: 35px;
      height: 35px;
    }

    .ai-collection-slider-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-collection-slider-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.8 }}px;
    }

    .ai-collection-slide-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.card_title_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<collection-slider-{{ ai_gen_id }} class="ai-collection-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-collection-slider-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-collection-slider-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-collection-slider-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.collections != blank %}
    <div class="ai-collection-slider-container-{{ ai_gen_id }}">
      <button
        class="ai-collection-slider-nav-{{ ai_gen_id }} ai-collection-slider-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
        data-nav="prev"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-collection-slider-track-{{ ai_gen_id }}">
        {% for collection in block.settings.collections %}
          <div class="ai-collection-slide-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-collection-slide-link-{{ ai_gen_id }}">
              <div class="ai-collection-slide-image-wrapper-{{ ai_gen_id }}">
                {% if collection.featured_image %}
                  <img
                    src="{{ collection.featured_image | image_url: width: 600 }}"
                    alt="{{ collection.featured_image.alt | escape }}"
                    class="ai-collection-slide-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="750"
                  >
                {% else %}
                  <div class="ai-collection-slide-image-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
                <div class="ai-collection-slide-overlay-{{ ai_gen_id }}">
                  <div class="ai-collection-slide-content-{{ ai_gen_id }}">
                    <h3 class="ai-collection-slide-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
                    {% if block.settings.show_product_count %}
                      <p class="ai-collection-slide-count-{{ ai_gen_id }}">{{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}</p>
                    {% endif %}
                    {% if block.settings.show_button %}
                      <span class="ai-collection-slide-button-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
                    {% endif %}
                  </div>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <button
        class="ai-collection-slider-nav-{{ ai_gen_id }} ai-collection-slider-nav-next-{{ ai_gen_id }}"
        aria-label="Next slide"
        data-nav="next"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-collection-slider-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  {% else %}
    <div class="ai-collection-empty-state-{{ ai_gen_id }}">
      {{ 'collection-1' | placeholder_svg_tag }}
      <p>Select collections to display in the slider</p>
    </div>
  {% endif %}
</collection-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-collection-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-collection-slide-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('[data-nav="prev"]');
        this.nextBtn = this.querySelector('[data-nav="next"]');
        this.dotsContainer = this.querySelector('.ai-collection-slider-dots-{{ ai_gen_id }}');
        this.currentIndex = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplayInterval = null;
      }

      connectedCallback() {
        if (!this.track || this.slides.length === 0) return;

        this.updateSlidesPerView();
        this.createDots();
        this.updateNavigation();
        this.setupEventListeners();

        if (this.autoplay) {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => this.updateSlidesPerView());
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 2;
        } else if (width <= 989) {
          this.slidesPerView = 3;
        } else {
          this.slidesPerView = {{ block.settings.slides_per_view }};
        }
        this.updateDots();
      }

      createDots() {
        if (!this.dotsContainer) return;

        const totalPages = Math.ceil(this.slides.length / this.slidesPerView);
        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < totalPages; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-collection-slider-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToPage(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateDots() {
        if (!this.dotsContainer) return;
        this.createDots();
        const dots = this.dotsContainer.querySelectorAll('.ai-collection-slider-dot-{{ ai_gen_id }}');
        const currentPage = Math.floor(this.currentIndex / this.slidesPerView);
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === currentPage);
        });
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => {
            this.prev();
            this.resetAutoplay();
          });
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => {
            this.next();
            this.resetAutoplay();
          });
        }

        this.track.addEventListener('scroll', () => {
          this.updateCurrentIndex();
        });
      }

      updateCurrentIndex() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.slide_gap }};
        this.currentIndex = Math.round(this.track.scrollLeft / (slideWidth + gap));
        this.updateNavigation();
        this.updateDots();
      }

      updateNavigation() {
        if (!this.prevBtn || !this.nextBtn) return;

        this.prevBtn.disabled = this.currentIndex === 0;
        this.nextBtn.disabled = this.currentIndex >= this.slides.length - this.slidesPerView;
      }

      scrollToIndex(index) {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.slide_gap }};
        const scrollPosition = index * (slideWidth + gap);
        this.track.scrollTo({
          left: scrollPosition,
          behavior: 'smooth'
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex = Math.max(0, this.currentIndex - this.slidesPerView);
          this.scrollToIndex(this.currentIndex);
        }
      }

      next() {
        if (this.currentIndex < this.slides.length - this.slidesPerView) {
          this.currentIndex = Math.min(
            this.slides.length - this.slidesPerView,
            this.currentIndex + this.slidesPerView
          );
          this.scrollToIndex(this.currentIndex);
        }
      }

      goToPage(pageIndex) {
        this.currentIndex = pageIndex * this.slidesPerView;
        this.scrollToIndex(this.currentIndex);
        this.resetAutoplay();
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          if (this.currentIndex >= this.slides.length - this.slidesPerView) {
            this.currentIndex = 0;
          } else {
            this.currentIndex += this.slidesPerView;
          }
          this.scrollToIndex(this.currentIndex);
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        if (this.autoplay) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('collection-slider-{{ ai_gen_id }}', CollectionSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection slider",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "Shop by collection"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover our curated collections"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "range",
      "id": "slides_per_view",
      "label": "Slides per view",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show navigation dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Card settings"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
