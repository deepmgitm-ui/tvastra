{% doc %}
  @prompt
    I want to build a slider of banners with one title and 2 buttons 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-banner-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slider_height }}px;
  }

  .ai-banner-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
    height: 100%;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: {{ block.settings.content_vertical_alignment }};
    justify-content: {{ block.settings.content_horizontal_alignment }};
  }

  .ai-banner-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-banner-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-banner-slider__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: {{ block.settings.text_alignment }};
    padding: 40px;
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-banner-slider__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    margin: 0 0 20px;
    font-weight: {{ block.settings.title_font_weight }};
  }

  .ai-banner-slider__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    margin-top: 30px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    flex-wrap: wrap;
  }

  .ai-banner-slider__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid;
    font-weight: 500;
  }

  .ai-banner-slider__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text }};
    border-color: {{ block.settings.button_primary_border }};
  }

  .ai-banner-slider__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_bg_hover }};
    color: {{ block.settings.button_primary_text_hover }};
    border-color: {{ block.settings.button_primary_border_hover }};
  }

  .ai-banner-slider__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-banner-slider__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_bg_hover }};
    color: {{ block.settings.button_secondary_text_hover }};
    border-color: {{ block.settings.button_secondary_border_hover }};
  }

  .ai-banner-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.8;
  }

  .ai-banner-slider__nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.nav_bg_hover_color }};
  }

  .ai-banner-slider__nav--prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-banner-slider__nav--next-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-banner-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slider__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height_mobile }}px;
    }

    .ai-banner-slider__content-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-banner-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.6 }}px;
    }

    .ai-banner-slider__buttons-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-banner-slider__nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-banner-slider__nav--prev-{{ ai_gen_id }} {
      left: 10px;
    }

    .ai-banner-slider__nav--next-{{ ai_gen_id }} {
      right: 10px;
    }
  }
{% endstyle %}

<banner-slider-{{ ai_gen_id }} class="ai-banner-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-slider__wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-slider__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_title_key = 'slide_' | append: i | append: '_title'
          assign slide_button1_text_key = 'slide_' | append: i | append: '_button1_text'
          assign slide_button1_link_key = 'slide_' | append: i | append: '_button1_link'
          assign slide_button2_text_key = 'slide_' | append: i | append: '_button2_text'
          assign slide_button2_link_key = 'slide_' | append: i | append: '_button2_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_title = block.settings[slide_title_key]
          assign slide_button1_text = block.settings[slide_button1_text_key]
          assign slide_button1_link = block.settings[slide_button1_link_key]
          assign slide_button2_text = block.settings[slide_button2_text_key]
          assign slide_button2_link = block.settings[slide_button2_link_key]
        %}

        {% if slide_enabled %}
          <div class="ai-banner-slider__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-banner-slider__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-banner-slider__image-placeholder-{{ ai_gen_id }}">
                {{ 'lifestyle-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if block.settings.show_overlay %}
              <div class="ai-banner-slider__overlay-{{ ai_gen_id }}"></div>
            {% endif %}

            <div class="ai-banner-slider__content-{{ ai_gen_id }}">
              {% if slide_title != blank %}
                <h2 class="ai-banner-slider__title-{{ ai_gen_id }}">{{ slide_title }}</h2>
              {% endif %}

              <div class="ai-banner-slider__buttons-{{ ai_gen_id }}">
                {% if slide_button1_text != blank %}
                  <a
                    href="{{ slide_button1_link }}"
                    class="ai-banner-slider__button-{{ ai_gen_id }} ai-banner-slider__button--primary-{{ ai_gen_id }}"
                  >
                    {{ slide_button1_text }}
                  </a>
                {% endif %}

                {% if slide_button2_text != blank %}
                  <a
                    href="{{ slide_button2_link }}"
                    class="ai-banner-slider__button-{{ ai_gen_id }} ai-banner-slider__button--secondary-{{ ai_gen_id }}"
                  >
                    {{ slide_button2_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_navigation %}
      <button
        class="ai-banner-slider__nav-{{ ai_gen_id }} ai-banner-slider__nav--prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-banner-slider__nav-{{ ai_gen_id }} ai-banner-slider__nav--next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-banner-slider__dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</banner-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-banner-slider__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-banner-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-banner-slider__nav--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-banner-slider__nav--next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-banner-slider__dots-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}

        this.updateSlider();
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-banner-slider__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
          if (index === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
        this.resetAutoplay();
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlider();
        this.resetAutoplay();
      }

      previousSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlider();
        this.resetAutoplay();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-banner-slider__dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            if (index === this.currentSlide) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('banner-slider-{{ ai_gen_id }}', BannerSlider{{ ai_gen_id }});
  })();
</script>

