{% doc %}
  @prompt
    A collection card that includes the collection image at the top, then the  title below. Add a smooth holographic shimmer effect and a shadow. and slider as well same for the mobile view 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-slider-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .ai-collection-slider-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-collection-slider-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_row | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row }});
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.card_bg_color }};
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: {{ block.settings.shadow_x }}px {{ block.settings.shadow_y | plus: block.settings.hover_lift }}px {{ block.settings.shadow_blur | plus: 10 }}px {{ block.settings.shadow_color }};
  }

  .ai-collection-card-link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collection-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-collection-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-holographic-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(255, 0, 255, 0.1) 0%,
      rgba(0, 255, 255, 0.1) 25%,
      rgba(255, 255, 0, 0.1) 50%,
      rgba(0, 255, 255, 0.1) 75%,
      rgba(255, 0, 255, 0.1) 100%
    );
    background-size: 400% 400%;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover .ai-holographic-overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.shimmer_opacity }};
    animation: ai-holographic-shimmer-{{ ai_gen_id }} {{ block.settings.shimmer_speed }}s ease infinite;
  }

  @keyframes ai-holographic-shimmer-{{ ai_gen_id }} {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .ai-collection-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-collection-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-collection-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.count_size }}px;
    color: {{ block.settings.count_color }};
    margin-top: 8px;
  }

  .ai-slider-nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 24px;
  }

  .ai-slider-btn-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: {{ block.settings.nav_bg_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
    color: {{ block.settings.nav_icon_color }};
  }

  .ai-slider-btn-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-slider-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-slider-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_mobile }});
    }

    .ai-collection-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-collection-count-{{ ai_gen_id }} {
      font-size: {{ block.settings.count_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<collection-slider-{{ ai_gen_id }} class="ai-collection-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-slider-wrapper-{{ ai_gen_id }}" data-slider-wrapper>
    {% if block.settings.collections != blank %}
      {% for collection in block.settings.collections %}
        <div class="ai-collection-card-{{ ai_gen_id }}">
          <a href="{{ collection.url }}" class="ai-collection-card-link-{{ ai_gen_id }}">
            <div class="ai-collection-image-wrapper-{{ ai_gen_id }}">
              {% if collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  class="ai-collection-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% elsif collection.products.first and collection.products.first.featured_image %}
                <img
                  src="{{ collection.products.first.featured_image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  class="ai-collection-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-collection-placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="ai-holographic-overlay-{{ ai_gen_id }}"></div>
            </div>
            <div class="ai-collection-content-{{ ai_gen_id }}">
              <h3 class="ai-collection-title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              {% if block.settings.show_product_count %}
                <div class="ai-collection-count-{{ ai_gen_id }}">
                  {{ collection.products_count }}
                  {% if collection.products_count == 1 %}
                    {{ block.settings.product_text }}
                  {% else %}
                    {{ block.settings.products_text }}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..6) %}
        <div class="ai-collection-card-{{ ai_gen_id }}">
          <div class="ai-collection-card-link-{{ ai_gen_id }}">
            <div class="ai-collection-image-wrapper-{{ ai_gen_id }}">
              <div class="ai-collection-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
              <div class="ai-holographic-overlay-{{ ai_gen_id }}"></div>
            </div>
            <div class="ai-collection-content-{{ ai_gen_id }}">
              <h3 class="ai-collection-title-{{ ai_gen_id }}">Collection {{ i }}</h3>
              {% if block.settings.show_product_count %}
                <div class="ai-collection-count-{{ ai_gen_id }}">0 {{ block.settings.products_text }}</div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if block.settings.show_navigation %}
    <div class="ai-slider-nav-{{ ai_gen_id }}">
      <button class="ai-slider-btn-{{ ai_gen_id }}" data-prev aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-slider-btn-{{ ai_gen_id }}" data-next aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</collection-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.wrapper = this.querySelector('[data-slider-wrapper]');
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.scrollAmount = 0;
      }

      connectedCallback() {
        if (this.prevBtn && this.nextBtn) {
          this.prevBtn.addEventListener('click', () => this.scroll('prev'));
          this.nextBtn.addEventListener('click', () => this.scroll('next'));
          this.wrapper.addEventListener('scroll', () => this.updateButtons());
          this.updateButtons();
        }
      }

      scroll(direction) {
        const cardWidth = this.wrapper.querySelector('.ai-collection-card-{{ ai_gen_id }}').offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollDistance = cardWidth + gap;

        if (direction === 'prev') {
          this.wrapper.scrollBy({ left: -scrollDistance, behavior: 'smooth' });
        } else {
          this.wrapper.scrollBy({ left: scrollDistance, behavior: 'smooth' });
        }
      }

      updateButtons() {
        const maxScroll = this.wrapper.scrollWidth - this.wrapper.clientWidth;
        this.prevBtn.disabled = this.wrapper.scrollLeft <= 0;
        this.nextBtn.disabled = this.wrapper.scrollLeft >= maxScroll - 1;
      }
    }

    customElements.define('collection-slider-{{ ai_gen_id }}', CollectionSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection card slider",
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections",
      "limit": 12
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "text",
      "id": "product_text",
      "label": "Product text (singular)",
      "default": "Product"
    },
    {
      "type": "text",
      "id": "products_text",
      "label": "Products text (plural)",
      "default": "Products"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "label": "Cards per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
