{% doc %}
  @prompt
    Create a fully responsive "Collection Slider Section".
    
    GOAL:
    Build a customizable horizontal slider (carousel) for collection cards.
    It must support:
    - Autoplay (on/off option)
    - Infinite loop
    - Smooth sliding animation
    - Fully responsive
    - Easy to duplicate slides
    - Fully customizable content
    
    SECTION REQUIREMENTS:
    - Full width section
    - Customizable background color
    - Centered container (max-width 1200–1400px)
    - Clean, modern ecommerce design
    
    SLIDER BEHAVIOR:
    
    DESKTOP (1200px+):
    - Show 3 slides at a time
    - Equal spacing between slides (24–32px)
    
    TABLET (768px–1199px):
    - Show 2 slides
    
    MOBILE (<768px):
    - Show 1 slide
    - Full width
    - Side padding 16–20px
    
    SLIDER FUNCTIONALITY:
    - Autoplay with adjustable speed
    - Pause on hover (desktop)
    - Infinite loop (seamless)
    - Smooth transition (0.4–0.6s ease)
    - Swipe support on mobile
    - Drag support on desktop (optional)
    - Navigation arrows (optional toggle)
    - Dots indicator (optional toggle)
    
    CARD STRUCTURE (Each Slide):
    
    1. Image container
       - Rounded corners (12–16px)
       - Overflow hidden
       - Object-fit: cover
       - Hover zoom effect
    
    2. Content area
       - Small label (customizable)
       - Title (customizable, multi-line)
       - Arrow/icon aligned right
       - Entire card clickable
    
    CUSTOMIZATION REQUIREMENTS:
    - No hardcoded text
    - All content dynamic
    - Adjustable:
      - Autoplay speed
      - Slides per view
      - Gap size
      - Background color
      - Border radius
    - Clean class naming
    - Production-ready code
    
    TECH REQUIREMENTS:
    - Use clean HTML, CSS, and JavaScript
    - Do NOT rely on heavy external libraries
    - If using a lightweight slider library, make it configurable
    - Code must be modular and easy to integrate
    
    Focus on structure, responsiveness, and smooth performance.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-collection-slider-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-collection-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-collection-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform {{ block.settings.transition_speed }}s ease;
    will-change: transform;
  }

  .ai-collection-slider-slide-{{ ai_gen_id }} {
    flex: 0 0 auto;
    padding: 0 {{ block.settings.slide_gap | divided_by: 2 }}px;
    box-sizing: border-box;
  }

  .ai-collection-card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .ai-collection-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 75%;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-collection-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover .ai-collection-card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collection-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px 0 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-collection-card-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
  }

  .ai-collection-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }

  .ai-collection-card-arrow-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-top: auto;
    padding-top: 12px;
  }

  .ai-collection-card-arrow-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.arrow_color }};
    transition: transform 0.3s ease;
  }

  .ai-collection-card-{{ ai_gen_id }}:hover .ai-collection-card-arrow-{{ ai_gen_id }} svg {
    transform: translateX(5px);
  }

  .ai-collection-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: {{ block.settings.nav_bg_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease, opacity 0.3s ease;
    opacity: 0.9;
  }

  .ai-collection-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
    opacity: 1;
  }

  .ai-collection-slider-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: {{ block.settings.nav_icon_color }};
  }

  .ai-collection-slider-nav-prev-{{ ai_gen_id }} {
    left: -20px;
  }

  .ai-collection-slider-nav-next-{{ ai_gen_id }} {
    right: -20px;
  }

  .ai-collection-slider-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .ai-collection-slider-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-collection-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (min-width: 1200px) {
    .ai-collection-slider-slide-{{ ai_gen_id }} {
      width: calc(100% / {{ block.settings.slides_desktop }});
    }
  }

  @media screen and (min-width: 768px) and (max-width: 1199px) {
    .ai-collection-slider-slide-{{ ai_gen_id }} {
      width: calc(100% / {{ block.settings.slides_tablet }});
    }
  }

  @media screen and (max-width: 767px) {
    .ai-collection-slider-slide-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-collection-slider-container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_padding }}px;
    }

    .ai-collection-slider-nav-{{ ai_gen_id }} {
      width: 35px;
      height: 35px;
    }

    .ai-collection-slider-nav-prev-{{ ai_gen_id }} {
      left: 5px;
    }

    .ai-collection-slider-nav-next-{{ ai_gen_id }} {
      right: 5px;
    }
  }
{% endstyle %}

<collection-slider-{{ ai_gen_id }}
  class="ai-collection-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.enable_autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-infinite="{{ block.settings.enable_infinite_loop }}"
  data-pause-on-hover="{{ block.settings.pause_on_hover }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-collection-slider-container-{{ ai_gen_id }}">
    <div class="ai-collection-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-collection-slider-track-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign collection_key = 'collection_' | append: i
            assign label_key = 'label_' | append: i
            assign title_key = 'title_' | append: i
            assign link_key = 'link_' | append: i
            assign image_key = 'image_' | append: i

            assign collection = block.settings[collection_key]
            assign label = block.settings[label_key]
            assign title = block.settings[title_key]
            assign link = block.settings[link_key]
            assign image = block.settings[image_key]

            if collection != blank
              assign final_title = collection.title
              assign final_link = collection.url
              assign final_image = collection.featured_image
            else
              assign final_title = title
              assign final_link = link
              assign final_image = image
            endif
          %}

          <div class="ai-collection-slider-slide-{{ ai_gen_id }}">
            <a
              href="{% if final_link != blank %}{{ final_link }}{% else %}#{% endif %}"
              class="ai-collection-card-{{ ai_gen_id }}"
            >
              <div class="ai-collection-card-image-wrapper-{{ ai_gen_id }}">
                {% if final_image != blank %}
                  <img
                    src="{{ final_image | image_url: width: 800 }}"
                    alt="{{ final_image.alt | escape }}"
                    loading="lazy"
                    class="ai-collection-card-image-{{ ai_gen_id }}"
                    width="800"
                    height="600"
                  >
                {% else %}
                  <div class="ai-collection-card-placeholder-{{ ai_gen_id }}">
                    {{ 'collection-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-collection-card-content-{{ ai_gen_id }}">
                {% if label != blank %}
                  <div class="ai-collection-card-label-{{ ai_gen_id }}">{{ label }}</div>
                {% endif %}

                {% if final_title != blank %}
                  <h3 class="ai-collection-card-title-{{ ai_gen_id }}">{{ final_title }}</h3>
                {% endif %}

                <div class="ai-collection-card-arrow-{{ ai_gen_id }}">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_navigation %}
        <button
          class="ai-collection-slider-nav-{{ ai_gen_id }} ai-collection-slider-nav-prev-{{ ai_gen_id }}"
          aria-label="Previous slide"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button
          class="ai-collection-slider-nav-{{ ai_gen_id }} ai-collection-slider-nav-next-{{ ai_gen_id }}"
          aria-label="Next slide"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-collection-slider-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</collection-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.animationID = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-collection-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-collection-slider-slide-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-collection-slider-nav-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-collection-slider-nav-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-collection-slider-dots-{{ ai_gen_id }}');

        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 3000;
        this.infinite = this.dataset.infinite === 'true';
        this.pauseOnHover = this.dataset.pauseOnHover === 'true';

        this.slidesPerView = this.getSlidesPerView();
        this.totalSlides = this.slides.length;
        this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);

        this.setupEventListeners();
        this.createDots();
        this.updateSlider();

        if (this.autoplay) {
          this.startAutoplay();
        }

        window.addEventListener('resize', () => {
          this.slidesPerView = this.getSlidesPerView();
          this.maxIndex = Math.max(0, this.totalSlides - this.slidesPerView);
          this.currentIndex = Math.min(this.currentIndex, this.maxIndex);
          this.updateSlider();
        });
      }

      getSlidesPerView() {
        const width = window.innerWidth;
        if (width >= 1200) return {{ block.settings.slides_desktop }};
        if (width >= 768) return {{ block.settings.slides_tablet }};
        return 1;
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }

        if (this.pauseOnHover && this.autoplay) {
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }

        this.track.addEventListener('touchstart', (e) => this.touchStart(e));
        this.track.addEventListener('touchmove', (e) => this.touchMove(e));
        this.track.addEventListener('touchend', () => this.touchEnd());

        this.track.addEventListener('mousedown', (e) => this.touchStart(e));
        this.track.addEventListener('mousemove', (e) => this.touchMove(e));
        this.track.addEventListener('mouseup', () => this.touchEnd());
        this.track.addEventListener('mouseleave', () => this.touchEnd());
      }

      touchStart(event) {
        this.isDragging = true;
        this.startPos = this.getPositionX(event);
        this.animationID = requestAnimationFrame(() => this.animation());
        this.track.style.cursor = 'grabbing';
      }

      touchMove(event) {
        if (this.isDragging) {
          const currentPosition = this.getPositionX(event);
          this.currentTranslate = this.prevTranslate + currentPosition - this.startPos;
        }
      }

      touchEnd() {
        this.isDragging = false;
        cancelAnimationFrame(this.animationID);

        const movedBy = this.currentTranslate - this.prevTranslate;

        if (movedBy < -50 && this.currentIndex < this.maxIndex) {
          this.next();
        } else if (movedBy > 50 && this.currentIndex > 0) {
          this.prev();
        } else {
          this.updateSlider();
        }

        this.track.style.cursor = 'grab';
      }

      getPositionX(event) {
        return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
      }

      animation() {
        if (this.isDragging) {
          this.track.style.transform = `translateX(${this.currentTranslate}px)`;
          requestAnimationFrame(() => this.animation());
        }
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.dotsContainer.innerHTML = '';
        const numDots = this.maxIndex + 1;

        for (let i = 0; i < numDots; i++) {
          const dot = document.createElement('button');
          dot.classList.add('ai-collection-slider-dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === 0) dot.classList.add('active');

          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.updateSlider();
            if (this.autoplay) {
              this.stopAutoplay();
              this.startAutoplay();
            }
          });

          this.dotsContainer.appendChild(dot);
        }
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const offset = -this.currentIndex * slideWidth;

        this.track.style.transform = `translateX(${offset}px)`;
        this.prevTranslate = offset;
        this.currentTranslate = offset;

        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-collection-slider-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      next() {
        if (this.currentIndex < this.maxIndex) {
          this.currentIndex++;
        } else if (this.infinite) {
          this.currentIndex = 0;
        }
        this.updateSlider();
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
        } else if (this.infinite) {
          this.currentIndex = this.maxIndex;
        }
        this.updateSlider();
      }

      startAutoplay() {
        if (!this.autoplay) return;
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.next();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('collection-slider-{{ ai_gen_id }}', CollectionSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection slider",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Container max width",
      "min": 1200,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides per view (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides per view (tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slide_gap",
      "label": "Gap between slides",
      "min": 16,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
