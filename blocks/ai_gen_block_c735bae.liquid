{% doc %}
  @prompt
    Create a custom Testimonials section for Shopify Hongo 1.4 theme. Reference design: 3-column horizontal layout with circular customer profile photos on the left of each card, 5-star ratings, review text, customer name with "VERIFIED PURCHASE" badge. Full customization: section background color, card background color, star color, review text color & font size, customer name color, verified purchase text color & toggle, uploadable profile image per block, up to 6 testimonial blocks each fully editable (image, stars, review text, name, verified badge), optional section heading with color & font size, card border radius, card padding, gap between cards, 3 columns desktop / 1 column mobile, section top & bottom padding, verified purchase checkmark icon with color control, clean minimal design with circular cropped profile photos.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1220px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_bottom_margin }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: 600;
  }

  .ai-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-testimonial-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ai-testimonial-image-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-testimonial-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-testimonial-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 8px;
  }

  .ai-testimonial-star-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    fill: {{ block.settings.star_color }};
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.customer_name_color }};
    margin: 0 0 4px;
  }

  .ai-testimonial-verified-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: {{ block.settings.verified_text_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-testimonial-checkmark-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    fill: {{ block.settings.checkmark_color }};
  }

  .ai-testimonial-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_font_size }}px;
    line-height: 1.6;
    color: {{ block.settings.review_text_color }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.8 }}px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.8 }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<testimonials-section-{{ ai_gen_id }} class="ai-testimonials-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.section_heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign enabled_key = 'testimonial_' | append: i | append: '_enabled'
          assign image_key = 'testimonial_' | append: i | append: '_image'
          assign rating_key = 'testimonial_' | append: i | append: '_rating'
          assign text_key = 'testimonial_' | append: i | append: '_text'
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign verified_key = 'testimonial_' | append: i | append: '_verified'

          assign enabled = block.settings[enabled_key]
          assign image = block.settings[image_key]
          assign rating = block.settings[rating_key]
          assign text = block.settings[text_key]
          assign name = block.settings[name_key]
          assign verified = block.settings[verified_key]
        %}

        {% if enabled %}
          <div class="ai-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-testimonial-header-{{ ai_gen_id }}">
              <div class="ai-testimonial-image-wrapper-{{ ai_gen_id }}">
                {% if image %}
                  <img
                    src="{{ image | image_url: width: 120 }}"
                    alt="{{ name | escape }}"
                    class="ai-testimonial-image-{{ ai_gen_id }}"
                    width="60"
                    height="60"
                    loading="lazy"
                  >
                {% else %}
                  <div class="ai-testimonial-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-testimonial-info-{{ ai_gen_id }}">
                <div class="ai-testimonial-stars-{{ ai_gen_id }}">
                  {% for star in (1..rating) %}
                    <svg class="ai-testimonial-star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>

                {% if name != blank %}
                  <h3 class="ai-testimonial-name-{{ ai_gen_id }}">{{ name }}</h3>
                {% endif %}

                {% if verified and block.settings.show_verified_badge %}
                  <div class="ai-testimonial-verified-{{ ai_gen_id }}">
                    <svg class="ai-testimonial-checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </svg>
                    <span>Verified Purchase</span>
                  </div>
                {% endif %}
              </div>
            </div>

            {% if text != blank %}
              <p class="ai-testimonial-text-{{ ai_gen_id }}">{{ text }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonials-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialsSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('testimonials-section-{{ ai_gen_id }}', TestimonialsSection{{ ai_gen_id }});
  })();
</script>

