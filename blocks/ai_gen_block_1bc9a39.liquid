{% doc %}
  @prompt
    i want a banner slider with one title and 2 buttons and make it mobile optimize make the buttons smaller in size form them to fit in one row in mobile and title size should be small in mobile 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-banner-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
  }

  .ai-banner-slider__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .ai-banner-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .ai-banner-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-banner-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-banner-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-banner-slider__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    width: 90%;
    max-width: 800px;
  }

  .ai-banner-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 1;
  }

  .ai-banner-slider__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    line-height: 1.2;
    margin: 0 0 30px;
    font-weight: 600;
  }

  .ai-banner-slider__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-banner-slider__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 30px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 2px solid transparent;
  }

  .ai-banner-slider__button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_color }};
    border-color: {{ block.settings.button_primary_bg }};
  }

  .ai-banner-slider__button-{{ ai_gen_id }}--primary:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    color: {{ block.settings.button_primary_hover_color }};
    border-color: {{ block.settings.button_primary_hover_bg }};
  }

  .ai-banner-slider__button-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_color }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-banner-slider__button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_color }};
    border-color: {{ block.settings.button_secondary_hover_border }};
  }

  .ai-banner-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    opacity: 0.8;
  }

  .ai-banner-slider__nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-banner-slider__nav-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-banner-slider__nav-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-banner-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .ai-banner-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-banner-slider__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.banner_height_mobile }}px;
    }

    .ai-banner-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
      margin: 0 0 20px;
    }

    .ai-banner-slider__buttons-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-banner-slider__button-{{ ai_gen_id }} {
      padding: 12px 20px;
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    .ai-banner-slider__nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-banner-slider__nav-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-banner-slider__nav-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<banner-slider-{{ ai_gen_id }} class="ai-banner-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-banner-slider__wrapper-{{ ai_gen_id }}">
    <div class="ai-banner-slider__slides-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_image = block.settings[slide_image_key]
        %}
        <div class="ai-banner-slider__slide-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-slide="{{ i }}">
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 2000 }}"
              alt="{{ slide_image.alt | escape }}"
              loading="lazy"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
              class="ai-banner-slider__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-banner-slider__placeholder-{{ ai_gen_id }}">
              {{ 'hero-apparel-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
          
          {% if block.settings.show_overlay %}
            <div class="ai-banner-slider__overlay-{{ ai_gen_id }}"></div>
          {% endif %}

          <div class="ai-banner-slider__content-{{ ai_gen_id }}">
            {% if block.settings.title != blank %}
              <h2 class="ai-banner-slider__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
            {% endif %}

            <div class="ai-banner-slider__buttons-{{ ai_gen_id }}">
              {% if block.settings.button_primary_label != blank %}
                <a
                  href="{{ block.settings.button_primary_link }}"
                  class="ai-banner-slider__button-{{ ai_gen_id }} ai-banner-slider__button-{{ ai_gen_id }}--primary"
                >
                  {{ block.settings.button_primary_label }}
                </a>
              {% endif %}

              {% if block.settings.button_secondary_label != blank %}
                <a
                  href="{{ block.settings.button_secondary_link }}"
                  class="ai-banner-slider__button-{{ ai_gen_id }} ai-banner-slider__button-{{ ai_gen_id }}--secondary"
                >
                  {{ block.settings.button_secondary_label }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if block.settings.show_navigation %}
      <button
        class="ai-banner-slider__nav-{{ ai_gen_id }} ai-banner-slider__nav-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-banner-slider__nav-{{ ai_gen_id }} ai-banner-slider__nav-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-banner-slider__dots-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          <button
            class="ai-banner-slider__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
            data-slide="{{ i }}"
            aria-label="Go to slide {{ i }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</banner-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 3;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-banner-slider__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-banner-slider__dot-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-banner-slider__nav-{{ ai_gen_id }}--prev');
        this.nextBtn = this.querySelector('.ai-banner-slider__nav-{{ ai_gen_id }}--next');

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
          });
        });
      }

      goToSlide(slideNumber) {
        this.slides.forEach((slide) => {
          slide.classList.remove('active');
        });

        this.dots.forEach((dot) => {
          dot.classList.remove('active');
        });

        const targetSlide = this.querySelector(`[data-slide="${slideNumber}"].ai-banner-slider__slide-{{ ai_gen_id }}`);
        const targetDot = this.querySelector(`[data-slide="${slideNumber}"].ai-banner-slider__dot-{{ ai_gen_id }}`);

        if (targetSlide) {
          targetSlide.classList.add('active');
        }

        if (targetDot) {
          targetDot.classList.add('active');
        }

        this.currentSlide = slideNumber;

        {% if block.settings.autoplay %}
          this.resetAutoplay();
        {% endif %}
      }

      nextSlide() {
        const nextSlideNumber = this.currentSlide >= this.totalSlides ? 1 : this.currentSlide + 1;
        this.goToSlide(nextSlideNumber);
      }

      previousSlide() {
        const prevSlideNumber = this.currentSlide <= 1 ? this.totalSlides : this.currentSlide - 1;
        this.goToSlide(prevSlideNumber);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('banner-slider-{{ ai_gen_id }}', BannerSlider{{ ai_gen_id }});
  })();
</script>

