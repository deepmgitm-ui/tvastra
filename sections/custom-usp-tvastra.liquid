<!-- 👇 Icon Libraries 👇 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<section id="custom-features-{{ section.id }}" class="custom-features-section">
  <div class="{% if section.settings.full_width %}container-fluid{% else %}container{% endif %}">
    <div class="features-grid">
      {% for block in section.blocks %}
        <div class="feature-item feature-item-{{ block.id }}" {{ block.shopify_attributes }}>
          
          <!-- 🚀 ALL-IN-ONE ICON SELECTOR 🚀 -->
          <div class="feature-icon">
            {%- if block.settings.custom_image != blank -%}
              <img src="{{ block.settings.custom_image | image_url: width: 300 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- elsif block.settings.custom_svg != blank -%}
              <div class="svg-icon-wrapper">
                {{ block.settings.custom_svg }}
              </div>
            {%- elsif block.settings.icon_class != blank -%}
              <i class="{{ block.settings.icon_class }}"></i>
            {%- else -%}
              <i class="bi bi-star"></i>
            {%- endif -%}
          </div>

          <div class="feature-content">
            {%- if block.settings.title != blank -%}
              <h4 class="feature-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <p class="feature-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>

        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* =========================================
     ✨ MASTER FONTS LOADING ✨
  ========================================= */
  {%- if section.settings.title_font != blank and section.settings.use_futura_title == false -%}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.text_font != blank and section.settings.use_futura_text == false -%}
    {{ section.settings.text_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  /* =========================================
     SECTION LAYOUT & BACKGROUND
  ========================================= */
  #custom-features-{{ section.id }} {
    background-color: {{ section.settings.bg_color }} !important;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Grid Layout (PC = 4, Mobile = 2) */
  #custom-features-{{ section.id }} .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: start;
    row-gap: 40px;
  }

  #custom-features-{{ section.id }} .feature-item {
    text-align: center;
    position: relative;
    padding: 0 15px;
  }

  /* --- Divider Lines (Desktop - PC me 4 ek sath) --- */
  @media (min-width: 769px) {
    #custom-features-{{ section.id }} .feature-item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 15%;
      height: 70%;
      width: 1px;
      background-color: {{ section.settings.divider_color }} !important;
    }
  }

  /* =========================================
     ✨ 100% SHOPIFY CONTROLLED COLORS & SIZES ✨
  ========================================= */
  
  /* 1. Icon Control */
  #custom-features-{{ section.id }} .feature-icon {
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #custom-features-{{ section.id }} .feature-icon i {
    font-size: {{ section.settings.icon_size }}px !important;
    color: {{ section.settings.icon_color }} !important;
    line-height: 1;
  }

  #custom-features-{{ section.id }} .svg-icon-wrapper {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }} !important;
    display: flex;
  }
  #custom-features-{{ section.id }} .svg-icon-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  #custom-features-{{ section.id }} .feature-icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  /* 2. Title Control */
  #custom-features-{{ section.id }} .feature-title {
    {%- if section.settings.use_futura_title -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.title_font != blank -%}
        font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }} !important;
        font-weight: {{ section.settings.title_font.weight }} !important;
        font-style: {{ section.settings.title_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.title_size }}px !important;
    color: {{ section.settings.title_color }} !important;
    letter-spacing: {{ section.settings.title_spacing }}px !important;
    text-transform: uppercase;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  /* 3. Description Control */
  #custom-features-{{ section.id }} .feature-text {
    {%- if section.settings.use_futura_text -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.text_font != blank -%}
        font-family: {{ section.settings.text_font.family }}, {{ section.settings.text_font.fallback_families }} !important;
        font-weight: {{ section.settings.text_font.weight }} !important;
        font-style: {{ section.settings.text_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.text_size }}px !important;
    color: {{ section.settings.text_color }} !important;
    line-height: 1.6;
    margin: 0;
  }

  /* =========================================
     📱 MOBILE COMPACT LAYOUT 📱
  ========================================= */
  @media (max-width: 768px) {
    #custom-features-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }

    #custom-features-{{ section.id }} .features-grid {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 20px; /* Pehle 40px tha, ab 20px karke compact kar diya */
    }

    /* Mobile Divider Line */
    #custom-features-{{ section.id }} .feature-item:nth-child(odd)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 15%;
      height: 70%;
      width: 1px;
      background-color: {{ section.settings.divider_color }} !important;
    }

    #custom-features-{{ section.id }} .feature-item {
      padding: 0 10px; /* Padding kam kardi */
    }

    #custom-features-{{ section.id }} .feature-icon {
      margin-bottom: 10px !important; /* Icon aur text ka gap kam kiya */
    }

    #custom-features-{{ section.id }} .feature-title {
      font-size: calc({{ section.settings.title_size }}px * 0.8) !important;
      margin-bottom: 6px !important; /* Title aur description ka gap kam kiya */
    }

    #custom-features-{{ section.id }} .feature-text {
      font-size: calc({{ section.settings.text_size }}px * 0.9) !important;
      line-height: 1.3 !important;
    }

    #custom-features-{{ section.id }} .feature-icon i,
    #custom-features-{{ section.id }} .svg-icon-wrapper,
    #custom-features-{{ section.id }} .feature-icon img {
      width: calc({{ section.settings.icon_size }}px * 0.75) !important;
      height: calc({{ section.settings.icon_size }}px * 0.75) !important;
      font-size: calc({{ section.settings.icon_size }}px * 0.75) !important;
    }
  }

  @media (max-width: 768px) {
    #custom-features-{{ section.id }} {
      padding-top: 20px !important;
      padding-bottom: 18px !important;
      border-top: 1px solid #eeeeee;
      border-bottom: 1px solid #eeeeee;
    }

    #custom-features-{{ section.id }} .features-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: 18px;
    }

    #custom-features-{{ section.id }} .feature-item:nth-child(odd)::after {
      top: 12%;
      height: 76%;
      background-color: rgba(0, 0, 0, 0.14) !important;
    }

    #custom-features-{{ section.id }} .feature-item {
      min-height: 112px;
      padding: 0 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    #custom-features-{{ section.id }} .feature-title {
      font-size: {{ section.settings.title_size | at_least: 10 }}px !important;
      margin-bottom: 6px !important;
      line-height: 1.2 !important;
      letter-spacing: 0.3px !important;
    }

    #custom-features-{{ section.id }} .feature-text {
      font-size: {{ section.settings.text_size | at_least: 10 }}px !important;
      line-height: 1.35 !important;
      max-width: 132px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "Features (Icons + Text)",
  "settings": [
    {
      "type": "header",
      "content": "✨ Master Typography (Fonts)"
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Title Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_title",
      "label": "🔥 Use Custom Futura Font? (Title)",
      "default": false
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 10, "max": 40, "step": 1, "unit": "px",
      "label": "Title Size", "default": 16
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 0, "max": 10, "step": 1, "unit": "px",
      "label": "Title Letter Spacing", "default": 1
    },
    {
      "type": "font_picker",
      "id": "text_font",
      "label": "Description Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_text",
      "label": "🔥 Use Custom Futura Font? (Description)",
      "default": false
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 10, "max": 24, "step": 1, "unit": "px",
      "label": "Description Size", "default": 13
    },
    {
      "type": "header",
      "content": "✨ 100% Color Control Panel"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon/Logo Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Color",
      "default": "#a1a1a1"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Line Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20, "max": 120, "step": 2, "unit": "px",
      "label": "Icon Font Size", "default": 36
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width?",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (PC)",
      "min": 0, "max": 100, "step": 5, "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (PC)",
      "min": 0, "max": 100, "step": 5, "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0, "max": 80, "step": 2, "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0, "max": 80, "step": 2, "default": 30
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Box",
      "limit": 8,
      "settings": [
        {
          "type": "header",
          "content": "🔥 Logo Selection (Choose ONE method)"
        },
        {
          "type": "text",
          "id": "icon_class",
          "label": "Method 1: Class Name",
          "info": "E.g., 'bi bi-wind' or 'fas fa-running'. Leave blank if using image."
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Method 2: Custom SVG Code",
          "info": "Paste SVG code here. Overrides Class Name."
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Method 3: Image Upload",
          "info": "Upload PNG/JPG logo. Overrides both Class and SVG."
        },
        {
          "type": "header",
          "content": "Text Settings"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "LIGHTWEIGHT"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Feels like second skin, moves like you."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features (Icons + Text)",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon_class": "bi bi-feather",
            "title": "LIGHTWEIGHT",
            "text": "Feels like second skin, moves like you."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_class": "bi bi-wind",
            "title": "BREATHABLE",
            "text": "Advanced fabrics that keep you cool."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_class": "fas fa-running",
            "title": "BUILT FOR MOVEMENT",
            "text": "Flexible stretch for every rep, run & routine."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon_class": "bi bi-stars",
            "title": "EVERYDAY STYLE",
            "text": "Minimal designs that fit every moment."
          }
        }
      ]
    }
  ]
}
{% endschema %}