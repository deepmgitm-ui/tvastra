{%- liquid
  assign s = section.settings
  assign uid = section.id
  assign hero_alt = s.hero_image.alt | default: s.hero_heading
  assign story_alt = s.story_image.alt | default: s.story_heading
  assign lifestyle_alt = s.lifestyle_image.alt | default: s.lifestyle_heading
  assign cta_alt = s.cta_image.alt | default: s.cta_heading
-%}

<section
  id="about-tvastra-{{ uid }}"
  class="about-modern about-modern-{{ uid }}"
>
  <header class="am-hero">
    {%- if s.hero_image != blank -%}
      {{
        s.hero_image
        | image_url: width: 2600
        | image_tag:
          class: 'am-hero__image',
          widths: '750, 1100, 1500, 2000, 2600',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: hero_alt
      }}
    {%- endif -%}
    <div class="am-hero__overlay"></div>
    <div class="container am-hero__content">
      {%- if s.hero_eyebrow != blank -%}<p class="am-kicker am-kicker--light">{{ s.hero_eyebrow }}</p>{%- endif -%}
      <h1 class="am-hero__title alt-font">{{ s.hero_heading | default: page.title }}</h1>
      {%- if s.hero_statement != blank -%}<p class="am-hero__statement alt-font">{{ s.hero_statement }}</p>{%- endif -%}
      {%- if s.hero_text != blank -%}<div class="am-hero__text">{{ s.hero_text }}</div>{%- endif -%}
      {%- if s.hero_btn_text != blank -%}
        <a class="am-button am-button--light" href="{{ s.hero_btn_link | default: routes.all_products_collection_url }}">
          {{- s.hero_btn_text -}}
        </a>
      {%- endif -%}
    </div>
  </header>

  <div class="am-band am-intro">
    <div class="container am-intro__grid">
      <div>
        {%- if s.intro_eyebrow != blank -%}<p class="am-kicker">{{ s.intro_eyebrow }}</p>{%- endif -%}
        <h2 class="am-heading alt-font">{{ s.intro_heading }}</h2>
      </div>
      {%- if s.intro_text != blank -%}<div class="am-copy am-copy--lead">{{ s.intro_text }}</div>{%- endif -%}
    </div>
  </div>

  <div class="am-rhythm" aria-label="Tvastra design point of view">
    <div class="container am-rhythm__grid">
      <p>Move with ease.</p>
      <p>Feel like yourself.</p>
      <p>Wear it beyond the workout.</p>
    </div>
  </div>

  <div class="am-band am-story">
    <div class="container am-split">
      <div class="am-media am-media--portrait">
        {%- if s.story_image != blank -%}
          {{
            s.story_image
            | image_url: width: 1600
            | image_tag:
              class: 'am-media__image',
              widths: '550, 800, 1100, 1600',
              sizes: '(min-width: 992px) 50vw, 100vw',
              loading: 'lazy',
              alt: story_alt
          }}
        {%- endif -%}
      </div>
      <div class="am-split__content">
        {%- if s.story_eyebrow != blank -%}<p class="am-kicker">{{ s.story_eyebrow }}</p>{%- endif -%}
        <h2 class="am-heading alt-font">{{ s.story_heading }}</h2>
        {%- if s.story_text != blank -%}<div class="am-copy">{{ s.story_text }}</div>{%- endif -%}
        {%- if s.story_quote != blank -%}<p class="am-quote alt-font">{{ s.story_quote }}</p>{%- endif -%}
      </div>
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="am-band am-values">
      <div class="container">
        <div class="am-section-head">
          {%- if s.values_eyebrow != blank -%}<p class="am-kicker">{{ s.values_eyebrow }}</p>{%- endif -%}
          <h2 class="am-heading alt-font">{{ s.values_heading }}</h2>
        </div>
        <div class="am-values__grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'value' -%}
              <article class="am-value" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <i class="am-value__icon {{ block.settings.icon }}" aria-hidden="true"></i>
                {%- endif -%}
                <p class="am-value__number">0{{ forloop.index }}</p>
                <h3 class="am-value__title alt-font">{{ block.settings.title }}</h3>
                <p class="am-value__text">{{ block.settings.text }}</p>
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="am-band am-lifestyle">
    <div class="container am-lifestyle__grid">
      <div class="am-lifestyle__content">
        {%- if s.lifestyle_eyebrow != blank -%}<p class="am-kicker">{{ s.lifestyle_eyebrow }}</p>{%- endif -%}
        <h2 class="am-heading alt-font">{{ s.lifestyle_heading }}</h2>
        {%- if s.lifestyle_text != blank -%}<div class="am-copy">{{ s.lifestyle_text }}</div>{%- endif -%}
      </div>
      <div class="am-media am-media--lifestyle">
        {%- if s.lifestyle_image != blank -%}
          {{
            s.lifestyle_image
            | image_url: width: 1600
            | image_tag:
              class: 'am-media__image',
              widths: '550, 800, 1100, 1600',
              sizes: '(min-width: 992px) 56vw, 100vw',
              loading: 'lazy',
              alt: lifestyle_alt
          }}
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="am-mission">
    <div class="container am-mission__grid">
      <div class="am-mission__item">
        <p class="am-kicker am-kicker--gold">{{ s.mission_label }}</p>
        <div class="am-mission__copy alt-font">{{ s.mission_text }}</div>
      </div>
      <div class="am-mission__item">
        <p class="am-kicker am-kicker--gold">{{ s.vision_label }}</p>
        <div class="am-mission__copy alt-font">{{ s.vision_text }}</div>
      </div>
    </div>
  </div>

  {%- if s.show_gallery -%}
    <div class="am-band am-gallery">
      <div class="container">
        <div class="am-section-head am-section-head--wide">
          <div>
            {%- if s.gallery_eyebrow != blank -%}<p class="am-kicker">{{ s.gallery_eyebrow }}</p>{%- endif -%}
            <h2 class="am-heading alt-font">{{ s.gallery_heading }}</h2>
          </div>
        </div>
        <div class="am-gallery__grid">
          {%- for index in (1..3) -%}
            {%- assign image_key = 'gallery_image_' | append: index -%}
            {%- assign gallery_image = s[image_key] -%}
            {%- if gallery_image != blank -%}
              {%- assign gallery_alt = gallery_image.alt | default: 'Tvastra activewear in motion' -%}
              <figure class="am-gallery__item am-gallery__item--{{ index }}">
                {{
                  gallery_image
                  | image_url: width: 1400
                  | image_tag:
                    class: 'am-gallery__image',
                    widths: '450, 700, 1000, 1400',
                    sizes: '(min-width: 768px) 33vw, 100vw',
                    loading: 'lazy',
                    alt: gallery_alt
                }}
              </figure>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="am-cta">
    {%- if s.cta_image != blank -%}
      {{
        s.cta_image
        | image_url: width: 2400
        | image_tag:
          class: 'am-cta__image',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          loading: 'lazy',
          alt: cta_alt
      }}
    {%- endif -%}
    <div class="am-cta__overlay"></div>
    <div class="container am-cta__content">
      {%- if s.cta_eyebrow != blank -%}<p class="am-kicker am-kicker--light">{{ s.cta_eyebrow }}</p>{%- endif -%}
      <h2 class="am-cta__title alt-font">{{ s.cta_heading }}</h2>
      {%- if s.cta_text != blank -%}<div class="am-cta__text">{{ s.cta_text }}</div>{%- endif -%}
      <div class="am-cta__actions">
        {%- if s.cta_women_text != blank -%}
          <a class="am-button am-button--light" href="{{ s.cta_women_link }}">{{ s.cta_women_text }}</a>
        {%- endif -%}
        {%- if s.cta_men_text != blank -%}
          <a class="am-button am-button--outline" href="{{ s.cta_men_link }}">{{ s.cta_men_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{%- style -%}
  .about-modern-{{ uid }} {
    --am-ink: #111313;
    --am-paper: #ffffff;
    --am-soft: #f1f3f1;
    --am-forest: #173a35;
    --am-gold: #d0af29;
    --am-muted: #626766;
    background: var(--am-paper);
    color: var(--am-ink);
    overflow: hidden;
  }

  .about-modern-{{ uid }} *,
  .about-modern-{{ uid }} *::before,
  .about-modern-{{ uid }} *::after { letter-spacing: 0; }

  .about-modern-{{ uid }} .am-kicker {
    margin: 0 0 16px;
    color: var(--am-forest);
    font-size: 12px;
    line-height: 1.4;
    font-weight: 700;
    text-transform: uppercase;
  }

  .about-modern-{{ uid }} .am-kicker--light { color: #ffffff; }
  .about-modern-{{ uid }} .am-kicker--gold { color: var(--am-gold); }

  .about-modern-{{ uid }} .am-heading {
    margin: 0;
    max-width: 720px;
    color: var(--am-ink);
    font-size: 48px;
    line-height: 1.08;
    font-weight: 500;
  }

  .about-modern-{{ uid }} .am-copy {
    max-width: 620px;
    color: var(--am-muted);
    font-size: 17px;
    line-height: 1.8;
  }

  .about-modern-{{ uid }} .am-copy p { margin: 0 0 18px; }
  .about-modern-{{ uid }} .am-copy p:last-child { margin-bottom: 0; }
  .about-modern-{{ uid }} .am-copy--lead { font-size: 19px; }

  .about-modern-{{ uid }} .am-button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    padding: 13px 28px;
    border: 1px solid transparent;
    border-radius: 0;
    font-size: 13px;
    line-height: 1.2;
    font-weight: 700;
    text-transform: uppercase;
    transition: background-color .2s ease, color .2s ease, border-color .2s ease;
  }

  .about-modern-{{ uid }} .am-button--light { background: #ffffff; color: #111313; }
  .about-modern-{{ uid }} .am-button--light:hover { background: var(--am-gold); color: #111313; }
  .about-modern-{{ uid }} .am-button--outline { border-color: rgba(255,255,255,.75); color: #ffffff; }
  .about-modern-{{ uid }} .am-button--outline:hover { background: #ffffff; color: #111313; }

  .about-modern-{{ uid }} .am-hero {
    position: relative;
    height: 680px;
    height: calc(100svh - 150px);
    min-height: 520px;
    max-height: 760px;
    overflow: hidden;
    background: #171918;
  }

  .about-modern-{{ uid }} .am-hero__image,
  .about-modern-{{ uid }} .am-cta__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-modern-{{ uid }} .am-hero__image { object-position: {{ s.hero_image_position }}; }
  .about-modern-{{ uid }} .am-hero__overlay { position: absolute; inset: 0; background: rgba(8, 10, 10, .52); }

  .about-modern-{{ uid }} .am-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    height: 100%;
    max-width: 760px;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    padding-top: 72px;
    padding-bottom: 72px;
  }

  .about-modern-{{ uid }} .am-hero__title {
    margin: 0 0 10px;
    color: #ffffff;
    font-size: 76px;
    line-height: 1;
    font-weight: 500;
  }

  .about-modern-{{ uid }} .am-hero__statement {
    max-width: 700px;
    margin: 0 0 20px;
    color: #ffffff;
    font-size: 32px;
    line-height: 1.2;
    font-weight: 400;
  }

  .about-modern-{{ uid }} .am-hero__text {
    max-width: 540px;
    margin-bottom: 30px;
    color: rgba(255,255,255,.88);
    font-size: 16px;
    line-height: 1.7;
  }

  .about-modern-{{ uid }} .am-hero__text p { margin: 0; }
  .about-modern-{{ uid }} .am-band { padding: 104px 0; }

  .about-modern-{{ uid }} .am-intro__grid {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: 80px;
    align-items: start;
  }

  .about-modern-{{ uid }} .am-rhythm { padding: 32px 0; background: var(--am-forest); color: #ffffff; }
  .about-modern-{{ uid }} .am-rhythm__grid { display: grid; grid-template-columns: repeat(3, 1fr); }
  .about-modern-{{ uid }} .am-rhythm p {
    margin: 0;
    padding: 8px 32px;
    border-right: 1px solid rgba(255,255,255,.24);
    font-size: 17px;
    line-height: 1.4;
    text-align: center;
  }
  .about-modern-{{ uid }} .am-rhythm p:last-child { border-right: 0; }

  .about-modern-{{ uid }} .am-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 88px;
    align-items: center;
  }

  .about-modern-{{ uid }} .am-media { position: relative; overflow: hidden; background: var(--am-soft); }
  .about-modern-{{ uid }} .am-media--portrait { aspect-ratio: 4 / 5; }
  .about-modern-{{ uid }} .am-media--lifestyle { aspect-ratio: 5 / 6; }
  .about-modern-{{ uid }} .am-media__image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-modern-{{ uid }} .am-media--portrait .am-media__image { object-position: center 34%; }
  .about-modern-{{ uid }} .am-media--lifestyle .am-media__image { object-position: center; }

  .about-modern-{{ uid }} .am-quote {
    max-width: 560px;
    margin: 38px 0 0;
    padding: 4px 0 4px 24px;
    border-left: 3px solid var(--am-gold);
    color: var(--am-ink);
    font-size: 24px;
    line-height: 1.45;
  }

  .about-modern-{{ uid }} .am-values { background: var(--am-soft); }
  .about-modern-{{ uid }} .am-section-head { max-width: 720px; margin-bottom: 56px; }
  .about-modern-{{ uid }} .am-values__grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 28px; }
  .about-modern-{{ uid }} .am-value { position: relative; padding: 30px 0 0; border-top: 2px solid #c9cecb; }
  .about-modern-{{ uid }} .am-value__icon { display: block; margin-bottom: 34px; color: var(--am-forest); font-size: 28px; }
  .about-modern-{{ uid }} .am-value__number { position: absolute; top: 28px; right: 0; margin: 0; color: #909795; font-size: 12px; }
  .about-modern-{{ uid }} .am-value__title { margin: 0 0 12px; color: var(--am-ink); font-size: 21px; line-height: 1.25; }
  .about-modern-{{ uid }} .am-value__text { margin: 0; color: var(--am-muted); font-size: 15px; line-height: 1.7; }

  .about-modern-{{ uid }} .am-lifestyle__grid {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    gap: 88px;
    align-items: center;
  }

  .about-modern-{{ uid }} .am-lifestyle__content { padding-left: 24px; }

  .about-modern-{{ uid }} .am-mission { padding: 96px 0; background: #111313; color: #ffffff; }
  .about-modern-{{ uid }} .am-mission__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .about-modern-{{ uid }} .am-mission__item { padding: 0 72px; border-right: 1px solid rgba(255,255,255,.2); }
  .about-modern-{{ uid }} .am-mission__item:first-child { padding-left: 0; }
  .about-modern-{{ uid }} .am-mission__item:last-child { padding-right: 0; border-right: 0; }
  .about-modern-{{ uid }} .am-mission__copy { max-width: 520px; color: #ffffff; font-size: 27px; line-height: 1.45; }
  .about-modern-{{ uid }} .am-mission__copy p { margin: 0; }

  .about-modern-{{ uid }} .am-section-head--wide { max-width: 100%; }
  .about-modern-{{ uid }} .am-gallery__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  .about-modern-{{ uid }} .am-gallery__item { aspect-ratio: 3 / 4; margin: 0; overflow: hidden; background: var(--am-soft); }
  .about-modern-{{ uid }} .am-gallery__image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .about-modern-{{ uid }} .am-gallery__item--1 .am-gallery__image { object-position: center top; }
  .about-modern-{{ uid }} .am-gallery__item--2 .am-gallery__image { object-position: center top; }

  .about-modern-{{ uid }} .am-cta {
    position: relative;
    display: flex;
    min-height: 580px;
    align-items: center;
    overflow: hidden;
    background: #111313;
  }

  .about-modern-{{ uid }} .am-cta__image { object-position: center 36%; }
  .about-modern-{{ uid }} .am-cta__overlay { position: absolute; inset: 0; background: rgba(7, 9, 9, .62); }
  .about-modern-{{ uid }} .am-cta__content { position: relative; z-index: 1; max-width: 720px; text-align: center; }
  .about-modern-{{ uid }} .am-cta__title { margin: 0 0 20px; color: #ffffff; font-size: 54px; line-height: 1.08; font-weight: 500; }
  .about-modern-{{ uid }} .am-cta__text { max-width: 560px; margin: 0 auto 32px; color: rgba(255,255,255,.88); font-size: 17px; line-height: 1.7; }
  .about-modern-{{ uid }} .am-cta__text p { margin: 0; }
  .about-modern-{{ uid }} .am-cta__actions { display: flex; justify-content: center; gap: 12px; }

  @media (max-width: 991px) {
    .about-modern-{{ uid }} .am-heading { font-size: 40px; }
    .about-modern-{{ uid }} .am-band { padding: 80px 0; }
    .about-modern-{{ uid }} .am-intro__grid,
    .about-modern-{{ uid }} .am-split,
    .about-modern-{{ uid }} .am-lifestyle__grid { grid-template-columns: 1fr; gap: 48px; }
    .about-modern-{{ uid }} .am-copy { max-width: 720px; }
    .about-modern-{{ uid }} .am-lifestyle__content { padding-left: 0; }
    .about-modern-{{ uid }} .am-lifestyle__content { order: 2; }
    .about-modern-{{ uid }} .am-lifestyle .am-media { order: 1; }
    .about-modern-{{ uid }} .am-values__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 44px 28px; }
    .about-modern-{{ uid }} .am-mission__item { padding: 0 40px; }
    .about-modern-{{ uid }} .am-mission__copy { font-size: 23px; }
  }

  @media (max-width: 767px) {
    .about-modern-{{ uid }} .am-hero {
      height: 560px;
      height: calc(100svh - 150px);
      min-height: 480px;
      max-height: 620px;
    }
    .about-modern-{{ uid }} .am-hero__image { object-position: 46% center; }
    .about-modern-{{ uid }} .am-hero__content { padding-top: 40px; padding-bottom: 40px; }
    .about-modern-{{ uid }} .am-hero__title { font-size: 48px; }
    .about-modern-{{ uid }} .am-hero__statement { font-size: 24px; }
    .about-modern-{{ uid }} .am-hero__text { font-size: 15px; }
    .about-modern-{{ uid }} .am-heading { font-size: 34px; }
    .about-modern-{{ uid }} .am-copy,
    .about-modern-{{ uid }} .am-copy--lead { font-size: 16px; }
    .about-modern-{{ uid }} .am-band { padding: 64px 0; }
    .about-modern-{{ uid }} .am-rhythm { padding: 0; }
    .about-modern-{{ uid }} .am-rhythm__grid { grid-template-columns: 1fr; }
    .about-modern-{{ uid }} .am-rhythm p { padding: 20px 0; border-right: 0; border-bottom: 1px solid rgba(255,255,255,.24); }
    .about-modern-{{ uid }} .am-rhythm p:last-child { border-bottom: 0; }
    .about-modern-{{ uid }} .am-media--portrait,
    .about-modern-{{ uid }} .am-media--lifestyle { aspect-ratio: 4 / 5; }
    .about-modern-{{ uid }} .am-quote { margin-top: 30px; font-size: 21px; }
    .about-modern-{{ uid }} .am-section-head { margin-bottom: 40px; }
    .about-modern-{{ uid }} .am-values__grid { grid-template-columns: 1fr; gap: 36px; }
    .about-modern-{{ uid }} .am-mission { padding: 64px 0; }
    .about-modern-{{ uid }} .am-mission__grid { grid-template-columns: 1fr; gap: 48px; }
    .about-modern-{{ uid }} .am-mission__item,
    .about-modern-{{ uid }} .am-mission__item:first-child,
    .about-modern-{{ uid }} .am-mission__item:last-child { padding: 0 0 48px; border-right: 0; border-bottom: 1px solid rgba(255,255,255,.2); }
    .about-modern-{{ uid }} .am-mission__item:last-child { padding-bottom: 0; border-bottom: 0; }
    .about-modern-{{ uid }} .am-gallery__grid { grid-template-columns: 1fr 1fr; gap: 8px; }
    .about-modern-{{ uid }} .am-gallery__item--1 { grid-column: 1 / -1; aspect-ratio: 4 / 5; }
    .about-modern-{{ uid }} .am-cta { min-height: 520px; }
    .about-modern-{{ uid }} .am-cta__title { font-size: 38px; }
    .about-modern-{{ uid }} .am-cta__actions { flex-direction: column; align-items: stretch; }
    .about-modern-{{ uid }} .am-button { width: 100%; }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "About Tvastra",
  "tag": "section",
  "class": "section-about-modern",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "select", "id": "hero_image_position", "label": "Hero image position", "default": "center center", "options": [
      { "value": "left center", "label": "Left" },
      { "value": "center center", "label": "Center" },
      { "value": "right center", "label": "Right" }
    ] },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Activewear for real life" },
    { "type": "text", "id": "hero_heading", "label": "Heading", "default": "Tvastra Fit" },
    { "type": "text", "id": "hero_statement", "label": "Statement", "default": "Made for the decision to move." },
    { "type": "richtext", "id": "hero_text", "label": "Text", "default": "<p>Activewear designed for training, everyday movement, and everything in between.</p>" },
    { "type": "text", "id": "hero_btn_text", "label": "Button text", "default": "Explore the collection" },
    { "type": "url", "id": "hero_btn_link", "label": "Button link" },

    { "type": "header", "content": "Introduction" },
    { "type": "text", "id": "intro_eyebrow", "label": "Eyebrow", "default": "Our point of view" },
    { "type": "text", "id": "intro_heading", "label": "Heading", "default": "Movement does not need a stage." },
