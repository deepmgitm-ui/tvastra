<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

{%- liquid
  assign cta_heading = section.settings.main_heading
  if cta_heading == blank or cta_heading == 'Join Our Community'
    assign cta_heading = 'Join the Tvastra movement'
  endif

  assign cta_handle = section.settings.insta_handle
  if cta_handle == blank or cta_handle == 'Instagram @tvastra.fit'
    assign cta_handle = 'Follow @tvastra.fit'
  endif

  assign cta_bg = section.settings.bg_color
  if cta_bg == blank or cta_bg == '#f9f9f9'
    assign cta_bg = '#050507'
  endif

  assign cta_heading_color = section.settings.heading_color
  if cta_heading_color == blank or cta_heading_color == '#444444'
    assign cta_heading_color = '#ffffff'
  endif

  assign cta_icon_color = section.settings.icon_color
  if cta_icon_color == blank or cta_icon_color == '#111111'
    assign cta_icon_color = '#070707'
  endif

  assign cta_handle_color = section.settings.handle_color
  if cta_handle_color == blank or cta_handle_color == '#111111'
    assign cta_handle_color = '#070707'
  endif
-%}

<section id="insta-cta-{{ section.id }}" class="insta-cta-section">
  <div class="insta-cta-container">
    <span class="insta-kicker">TVASTRA COMMUNITY</span>

    {%- if cta_heading != blank -%}
      <h2 class="insta-heading">{{ cta_heading }}</h2>
    {%- endif -%}

    <p class="insta-copy">Built for everyday movement. Worn by people who train, travel, and keep showing up.</p>

    {%- if cta_handle != blank -%}
      <a {% if section.settings.insta_link != blank %}href="{{ section.settings.insta_link }}" target="_blank" rel="noopener"{% else %}role="link" aria-disabled="true"{% endif %} class="insta-handle">
        {%- if section.settings.show_icon -%}
          <span class="insta-icon" aria-hidden="true">
            {%- if section.settings.icon_image != blank -%}
              <img src="{{ section.settings.icon_image | image_url: width: 100 }}" alt="" loading="lazy">
            {%- elsif section.settings.icon_class != blank -%}
              <i class="{{ section.settings.icon_class }}"></i>
            {%- else -%}
              <i class="bi bi-instagram"></i>
            {%- endif -%}
          </span>
        {%- endif -%}

        <span class="insta-text">{{ cta_handle }}</span>
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  {%- if section.settings.handle_font != blank and section.settings.use_futura_handle == false -%}
    {{ section.settings.handle_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.heading_font != blank and section.settings.use_futura_heading == false -%}
    {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  #insta-cta-{{ section.id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ cta_bg }} !important;
    color: #ffffff;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  #insta-cta-{{ section.id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.06), transparent 24%, transparent 76%, rgba(255, 255, 255, 0.06));
  }

  #insta-cta-{{ section.id }} .insta-cta-container {
    position: relative;
    z-index: 1;
    width: calc(100% - 32px);
    max-width: 980px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      "kicker handle"
      "heading handle"
      "copy handle";
    gap: 10px 34px;
    align-items: center;
  }

  #insta-cta-{{ section.id }} .insta-kicker {
    grid-area: kicker;
    font-size: 10px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: 4px;
    color: rgba(255, 255, 255, 0.66);
    text-transform: uppercase;
  }

  #insta-cta-{{ section.id }} .insta-heading {
    grid-area: heading;
    {%- if section.settings.use_futura_heading -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.heading_font != blank -%}
        font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
        font-weight: {{ section.settings.heading_font.weight }} !important;
        font-style: {{ section.settings.heading_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    max-width: 620px;
    margin: 0 !important;
    font-size: {{ section.settings.heading_size }}px !important;
    line-height: 1.12;
    letter-spacing: {{ section.settings.heading_spacing }}px !important;
    color: {{ cta_heading_color }} !important;
    text-transform: uppercase;
  }

  #insta-cta-{{ section.id }} .insta-copy {
    grid-area: copy;
    max-width: 560px;
    margin: 0;
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.68);
  }

  #insta-cta-{{ section.id }} .insta-handle {
    grid-area: handle;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ section.settings.icon_gap }}px;
    padding: 0 20px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(255, 255, 255, 0.96);
    color: #070707;
    text-decoration: none;
    white-space: nowrap;
    transition: transform 0.22s ease, background 0.22s ease, border-color 0.22s ease;
  }

  #insta-cta-{{ section.id }} .insta-handle[href]:hover {
    transform: translateY(-2px);
    background: #ffffff;
    border-color: #ffffff;
  }

  #insta-cta-{{ section.id }} .insta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: {{ cta_icon_color }} !important;
  }

  #insta-cta-{{ section.id }} .insta-icon svg,
  #insta-cta-{{ section.id }} .insta-icon i {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    font-size: {{ section.settings.icon_size }}px;
    line-height: 1;
  }

  #insta-cta-{{ section.id }} .insta-icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  #insta-cta-{{ section.id }} .insta-text {
    {%- if section.settings.use_futura_handle -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.handle_font != blank -%}
        font-family: {{ section.settings.handle_font.family }}, {{ section.settings.handle_font.fallback_families }} !important;
        font-weight: {{ section.settings.handle_font.weight }} !important;
        font-style: {{ section.settings.handle_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.handle_size }}px !important;
    line-height: 1.2;
    letter-spacing: {{ section.settings.handle_spacing }}px !important;
    color: {{ cta_handle_color }} !important;
  }

  @media (max-width: 768px) {
    #insta-cta-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
    }

    #insta-cta-{{ section.id }} .insta-cta-container {
      width: calc(100% - 28px);
      max-width: 620px;
      grid-template-columns: 1fr;
      grid-template-areas:
        "kicker"
        "heading"
        "copy"
        "handle";
      gap: 12px;
      text-align: center;
      justify-items: center;
    }

    #insta-cta-{{ section.id }} .insta-kicker {
      font-size: 10px;
      letter-spacing: 3px;
    }

    #insta-cta-{{ section.id }} .insta-heading {
      max-width: 340px;
      font-size: 22px !important;
      line-height: 1.18;
    }

    #insta-cta-{{ section.id }} .insta-copy {
      max-width: 330px;
      font-size: 13px;
      line-height: 1.6;
    }

    #insta-cta-{{ section.id }} .insta-handle {
      width: 100%;
      max-width: 300px;
      min-height: 46px;
      margin-top: 4px;
      padding: 0 16px;
    }

    #insta-cta-{{ section.id }} .insta-text {
      font-size: 14px !important;
    }
  }

  @media (max-width: 768px) {
    #insta-cta-{{ section.id }} {
      padding-top: 38px !important;
      padding-bottom: 40px !important;
    }

    #insta-cta-{{ section.id }} .insta-cta-container {
      gap: 10px;
    }

    #insta-cta-{{ section.id }} .insta-heading {
      max-width: 320px;
      font-size: 21px !important;
      line-height: 1.16;
    }

    #insta-cta-{{ section.id }} .insta-copy {
      max-width: 310px;
      color: rgba(255, 255, 255, 0.72);
    }

    #insta-cta-{{ section.id }} .insta-handle {
      min-height: 48px;
      border-radius: 0;
    }
  }
</style>
{% schema %}
{
  "name": "Insta Community CTA",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "✨ Top Text (Main Heading)"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Heading Text",
      "default": "Join Our Community"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_heading",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20, "max": 80, "step": 1, "unit": "px",
      "label": "Heading Font Size", "default": 36
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0, "max": 10, "step": 1, "unit": "px",
      "label": "Letter Spacing", "default": 0
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#444444"
    },
    {
      "type": "header",
      "content": "✨ Bottom Text & Logo (Instagram)"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show Logo/Icon?",
      "default": true
    },
    {
      "type": "text",
      "id": "icon_class",
      "label": "Icon Class (Optional)",
      "info": "E.g., 'bi bi-instagram'. Leave blank for default Instagram logo."
    },
    {
      "type": "image_picker",
      "id": "icon_image",
      "label": "Custom Logo Image (Optional)"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 10, "max": 50, "step": 1, "unit": "px",
      "label": "Logo Size", "default": 20
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Logo Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "icon_gap",
      "min": 0, "max": 20, "step": 1, "unit": "px",
      "label": "Gap between Logo and Text", "default": 8
    },
    {
      "type": "text",
      "id": "insta_handle",
      "label": "Handle Text",
      "default": "Instagram @tvastra.fit"
    },
    {
      "type": "url",
      "id": "insta_link",
      "label": "Instagram Link (Optional)"
    },
    {
      "type": "font_picker",
      "id": "handle_font",
      "label": "Handle Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_handle",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "handle_size",
      "min": 10, "max": 40, "step": 1, "unit": "px",
      "label": "Handle Font Size", "default": 16
    },
    {
      "type": "range",
      "id": "handle_spacing",
      "min": 0, "max": 10, "step": 1, "unit": "px",
      "label": "Letter Spacing", "default": 0
    },
    {
      "type": "color",
      "id": "handle_color",
      "label": "Handle Text Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "📏 Spacing & Layout"
    },
    {
      "type": "range",
      "id": "text_gap",
      "min": 0, "max": 60, "step": 2, "unit": "px",
      "label": "Gap between Top and Bottom Texts",
      "default": 16
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (PC)",
      "min": 0, "max": 120, "step": 5, "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (PC)",
      "min": 0, "max": 120, "step": 5, "default": 60
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "min": 0, "max": 80, "step": 2, "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0, "max": 80, "step": 2, "default": 40
    }
  ],
  "presets": [
    {
      "name": "Insta Community CTA"
    }
  ]
}
{% endschema %}