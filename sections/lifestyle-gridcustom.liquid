<!-- 👇 Icon Libraries 👇 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<section id="lifestyle-grid-{{ section.id }}" class="lifestyle-section">
  
  {%- if section.settings.main_heading != blank -%}
    <h2 class="lifestyle-main-heading">{{ section.settings.main_heading }}</h2>
  {%- endif -%}

  <!-- PC pe edge-to-edge 100% width ke liye direct wrapper -->
  <div class="lifestyle-grid-container">
    {% for block in section.blocks %}
      <div class="lifestyle-block" {{ block.shopify_attributes }}>
        
        <!-- Background Image -->
        <div class="lifestyle-bg">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <!-- Custom Shadow / Overlay Layer -->
        <div class="lifestyle-overlay"></div>

        <!-- Content (Icon, Title, Subtitle) -->
        <div class="lifestyle-content">
          <div class="lifestyle-icon">
            {%- if block.settings.custom_image != blank -%}
              <img src="{{ block.settings.custom_image | image_url: width: 100 }}" alt="Icon" loading="lazy">
            {%- elsif block.settings.custom_svg != blank -%}
              <div class="svg-icon-wrapper">{{ block.settings.custom_svg }}</div>
            {%- elsif block.settings.icon_class != blank -%}
              <i class="{{ block.settings.icon_class }}"></i>
            {%- endif -%}
          </div>
          
          {%- if block.settings.title != blank -%}
            <h3 class="lifestyle-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          
          {%- if block.settings.subtitle != blank -%}
            <p class="lifestyle-subtitle">{{ block.settings.subtitle }}</p>
          {%- endif -%}
        </div>
        
      </div>
    {% endfor %}
  </div>

</section>

<style>
  /* =========================================
     ✨ MASTER FONTS LOADING ✨
  ========================================= */
  {%- if section.settings.heading_font != blank and section.settings.use_futura_heading == false -%}
    {{ section.settings.heading_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.title_font != blank and section.settings.use_futura_title == false -%}
    {{ section.settings.title_font | font_face: font_display: 'swap' }}
  {%- endif -%}
  {%- if section.settings.subtitle_font != blank and section.settings.use_futura_subtitle == false -%}
    {{ section.settings.subtitle_font | font_face: font_display: 'swap' }}
  {%- endif -%}

  /* =========================================
     SECTION LAYOUT & GRID (100% HORIZONTAL)
  ========================================= */
  #lifestyle-grid-{{ section.id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
    background-color: #000;
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  /* 4 Column Grid on PC - Pura Horizontal */
  #lifestyle-grid-{{ section.id }} .lifestyle-grid-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    width: 100%;
    height: {{ section.settings.height_pc }}px;
  }

  .lifestyle-block {
    position: relative;
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end; /* Text bottom me rakhne ke liye */
    align-items: center;
    text-align: center;
    padding: 40px 15px;
    overflow: hidden;
    border-right: 1px solid rgba(255,255,255,0.08); /* Subtle divider */
  }
  .lifestyle-block:last-child {
    border-right: none;
  }

  /* =========================================
     IMAGES & OVERLAY (SHADOW)
  ========================================= */
  .lifestyle-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 0;
    transition: transform 0.6s ease; /* Hover zoom effect */
  }
  .lifestyle-bg img, .lifestyle-bg svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lifestyle-block:hover .lifestyle-bg {
    transform: scale(1.05);
  }

  /* Dark Layer over Image */
  .lifestyle-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
    background: linear-gradient(
      to bottom, 
      {{ section.settings.overlay_color | color_modify: 'alpha', 0.8 }} 0%, 
      {{ section.settings.overlay_color | color_modify: 'alpha', section.settings.overlay_opacity }} 30%, 
      {{ section.settings.overlay_color | color_modify: 'alpha', section.settings.overlay_opacity }} 65%, 
      {{ section.settings.overlay_color | color_modify: 'alpha', 0.85 }} 100%
    );
  }

  /* =========================================
     TYPOGRAPHY & CONTENT
  ========================================= */
  .lifestyle-content {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  /* Main Floating Header (PC) */
  #lifestyle-grid-{{ section.id }} .lifestyle-main-heading {
    position: absolute;
    top: 35px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    width: 100%;
    text-align: center;
    margin: 0;
    padding: 0 20px;
    {%- if section.settings.use_futura_heading -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.heading_font != blank -%}
        font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
        font-weight: {{ section.settings.heading_font.weight }} !important;
        font-style: {{ section.settings.heading_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.heading_size }}px !important;
    color: {{ section.settings.heading_color }} !important;
    letter-spacing: {{ section.settings.heading_spacing }}px !important;
    text-transform: uppercase;
    text-shadow: 0 2px 15px rgba(0,0,0,0.8); /* PC me shadow chahiye taaki clear dikhe */
  }

  /* Icons */
  .lifestyle-icon {
    margin-bottom: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: {{ section.settings.text_color }};
  }
  .lifestyle-icon i {
    font-size: {{ section.settings.icon_size }}px;
    line-height: 1;
  }
  .svg-icon-wrapper {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
  }
  .svg-icon-wrapper svg {
    width: 100%; height: 100%; fill: currentColor;
  }
  .lifestyle-icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
  }

  /* Box Title */
  #lifestyle-grid-{{ section.id }} .lifestyle-title {
    margin: 0 0 6px 0;
    {%- if section.settings.use_futura_title -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.title_font != blank -%}
        font-family: {{ section.settings.title_font.family }}, {{ section.settings.title_font.fallback_families }} !important;
        font-weight: {{ section.settings.title_font.weight }} !important;
        font-style: {{ section.settings.title_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.title_size }}px !important;
    color: {{ section.settings.text_color }} !important;
    letter-spacing: {{ section.settings.title_spacing }}px !important;
    text-transform: uppercase;
  }

  /* Box Subtitle */
  #lifestyle-grid-{{ section.id }} .lifestyle-subtitle {
    margin: 0;
    {%- if section.settings.use_futura_subtitle -%}
      font-family: 'FuturaCustom', sans-serif !important;
    {%- else -%}
      {%- if section.settings.subtitle_font != blank -%}
        font-family: {{ section.settings.subtitle_font.family }}, {{ section.settings.subtitle_font.fallback_families }} !important;
        font-weight: {{ section.settings.subtitle_font.weight }} !important;
        font-style: {{ section.settings.subtitle_font.style }} !important;
      {%- endif -%}
    {%- endif -%}
    font-size: {{ section.settings.subtitle_size }}px !important;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }} !important;
    line-height: 1.4;
  }

  /* =========================================
     📱 MOBILE RESPONSIVE (Perfect Solution) 📱
  ========================================= */
  @media (max-width: 768px) {
    /* Section ko column mode diya taaki heading top par normal element ban jaye */
    #lifestyle-grid-{{ section.id }} {
      display: flex;
      flex-direction: column;
    }

    /* ✨ Mobile Heading Customization (Top Par Aayegi, Overlay Nahi Hogi) ✨ */
    #lifestyle-grid-{{ section.id }} .lifestyle-main-heading {
      position: relative !important;
      top: auto !important;
      left: auto !important;
      transform: none !important;
      padding: 30px 15px 20px 15px;
      font-size: {{ section.settings.heading_size_mobile }}px !important;
      text-shadow: none !important; /* Ab solid bg pe hai to shadow ki zarurat nahi */
    }

    #lifestyle-grid-{{ section.id }} .lifestyle-grid-container {
      grid-template-columns: repeat(2, 1fr); /* 2x2 Grid */
      height: auto; 
    }
    
    .lifestyle-block {
      /* Perfect Squares for Mobile */
      aspect-ratio: 1 / 1; 
      height: auto;
      padding: 15px 10px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      border-top: 1px solid rgba(255,255,255,0.08); 
    }
    
    .lifestyle-block:nth-child(1), .lifestyle-block:nth-child(2) {
      border-top: none;
    }
    
    .lifestyle-block:nth-child(even) {
      border-right: none;
    }

    #lifestyle-grid-{{ section.id }} .lifestyle-title {
      font-size: {{ section.settings.title_size_mobile }}px !important;
      margin-bottom: 4px;
    }
    
    #lifestyle-grid-{{ section.id }} .lifestyle-subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px !important;
      line-height: 1.2;
    }

    .lifestyle-icon {
      margin-bottom: 8px; /* Gap kam kardi */
    }
    .lifestyle-icon i, .svg-icon-wrapper, .lifestyle-icon img {
      font-size: calc({{ section.settings.icon_size }}px * 0.75);
      width: calc({{ section.settings.icon_size }}px * 0.75);
      height: calc({{ section.settings.icon_size }}px * 0.75);
    }
  }
</style>

{% schema %}
{
  "name": "Lifestyle Image Grid",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "✨ Main Header Settings"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "NOT JUST GYMWEAR"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_heading",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16, "max": 100, "step": 1, "unit": "px",
      "label": "Heading Font Size (Desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 10, "max": 80, "step": 1, "unit": "px",
      "label": "Heading Font Size (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0, "max": 15, "step": 1, "unit": "px",
      "label": "Heading Letter Spacing",
      "default": 4
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "✨ Grid Box Shadow & Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay / Shadow Color",
      "default": "#000000",
      "info": "This adds a dark layer over images to make text readable."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0, "max": 1, "step": 0.1,
      "label": "Middle Overlay Opacity",
      "default": 0.2
    },
    {
      "type": "header",
      "content": "📏 Dimensions (PC Only)"
    },
    {
      "type": "range",
      "id": "height_pc",
      "min": 300, "max": 800, "step": 20, "unit": "px",
      "label": "Section Height (Desktop)",
      "default": 600
    },
    {
      "type": "header",
      "content": "✨ Box Text Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Icon & Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 20, "max": 60, "step": 2, "unit": "px",
      "label": "Icon Size",
      "default": 32
    },
    {
      "type": "font_picker",
      "id": "title_font",
      "label": "Box Title Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_title",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 10, "max": 60, "step": 1, "unit": "px",
      "label": "Box Title Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 10, "max": 40, "step": 1, "unit": "px",
      "label": "Box Title Size (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "title_spacing",
      "min": 0, "max": 10, "step": 1, "unit": "px",
      "label": "Title Letter Spacing",
      "default": 2
    },
    {
      "type": "font_picker",
      "id": "subtitle_font",
      "label": "Box Subtitle Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_subtitle",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "min": 10, "max": 40, "step": 1, "unit": "px",
      "label": "Subtitle Font Size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "subtitle_size_mobile",
      "min": 10, "max": 30, "step": 1, "unit": "px",
      "label": "Subtitle Font Size (Mobile)",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "grid_box",
      "name": "Image Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "header",
          "content": "🔥 Icon Selection"
        },
        {
          "type": "text",
          "id": "icon_class",
          "label": "Method 1: Class Name",
          "info": "E.g., 'bi bi-heart-pulse' or 'fas fa-plane'."
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Method 2: Custom SVG Code"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Method 3: Image Upload (Logo)"
        },
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CATEGORY"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lifestyle Image Grid",
      "blocks": [
        {
          "type": "grid_box",
          "settings": {
            "icon_class": "bi bi-heart-pulse",
            "title": "GYM",
            "subtitle": "Built for performance"
          }
        },
        {
          "type": "grid_box",
          "settings": {
            "icon_class": "bi bi-cup-hot",
            "title": "COFFEE RUNS",
            "subtitle": "Style that goes beyond workouts"
          }
        },
        {
          "type": "grid_box",
          "settings": {
            "icon_class": "bi bi-airplane",
            "title": "TRAVEL",
            "subtitle": "Light, comfortable and easy to pack"
          }
        },
        {
          "type": "grid_box",
          "settings": {
            "icon_class": "bi bi-sun",
            "title": "EVERYDAY",
            "subtitle": "Designed for your everyday movement"
          }
        }
      ]
    }
  ]
}
{% endschema %}