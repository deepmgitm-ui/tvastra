      "id": "use_futura_heading",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 10, "max": 100, "step": 1, "unit": "px",
      "label": "Heading Size", "default": 42
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0, "max": 10, "step": 1, "unit": "px",
      "label": "Heading Letter Spacing", "default": 2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1b1b1b"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Subheading Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_subheading",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10, "max": 30, "step": 1, "unit": "px",
      "label": "Subheading Size", "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subheading Color",
      "default": "#777777"
    },
    {
      "type": "header",
      "content": "✨ Product Card Typography"
    },
    {
      "type": "font_picker",
      "id": "product_title_font",
      "label": "Product Title Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_title",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "product_title_size",
      "min": 10, "max": 30, "step": 1, "unit": "px",
      "label": "Product Title Size", "default": 16
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product Title Color",
      "default": "#1b1b1b"
    },
    {
      "type": "font_picker",
      "id": "product_price_font",
      "label": "Product Price Font",
      "default": "helvetica_n4"
    },
    {
      "type": "checkbox",
      "id": "use_futura_price",
      "label": "🔥 Use Custom Futura Font?",
      "default": false
    },
    {
      "type": "range",
      "id": "product_price_size",
      "min": 10, "max": 30, "step": 1, "unit": "px",
      "label": "Product Price Size", "default": 15
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Product Price Color",
      "default": "#777777"
    },
    {
      "type": "header",
      "content": "✨ Shapes & Borders"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0, "max": 50, "step": 1, "unit": "px",
      "label": "Product Card Shape (Border Radius)", "default": 0
