{% liquid
  assign best_collection = collections[section.settings.collection]
  assign desktop_show = section.settings.desktop_show | default: 4
  assign mobile_show = section.settings.mobile_show | default: 2
  assign autoplay_speed = section.settings.autoplay_speed | default: 3 | times: 1000
%}

<section
  id="bss-{{ section.id }}"
  class="bss-section"
  style="background:{{ section.settings.bg }};"
  aria-label="{{ section.settings.heading }}"
>
  <!-- Background dot pattern (Optional, tu isko CSS se hide kar sakta hai agar ye bhi nahi chahiye) -->
  <div class="bss-pattern bss-pattern-left" aria-hidden="true"></div>
  <div class="bss-pattern bss-pattern-right" aria-hidden="true"></div>

  <div class="bss-container">

    <header class="bss-header">
      <h2 class="bss-heading">
        {{ section.settings.heading }}
      </h2>
    </header>

    <p class="bss-subheading">
      {{ section.settings.subheading }}
    </p>

    <div class="bss-slider" role="region" aria-label="Product slider">

      {% if section.settings.show_arrows %}
      <button class="bss-arrow bss-arrow--prev" aria-label="Previous products">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      </button>
      {% endif %}

      <div class="bss-viewport">
        <div class="bss-track products {{ settings.product_card_style }} product-grid">

          {% if best_collection != blank %}
            {% for product in best_collection.products %}
              <div class="bss-card product-box">
                {% render 'product-card', product: product %}
              </div>
            {% else %}
              <div class="bss-empty"><p>No products found in this collection.</p></div>
            {% endfor %}
          {% else %}
            <div class="bss-empty"><p>Please select a collection in Theme Editor.</p></div>
          {% endif %}

        </div>
      </div>

      {% if section.settings.show_arrows %}
      <button class="bss-arrow bss-arrow--next" aria-label="Next products">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>
      {% endif %}

    </div>
  </div>
</section>

<style>
/* ================================================
  MASTER CUSTOMIZATION FONTS
================================================ */
{%- if section.settings.heading_font != blank and section.settings.use_futura_heading == false -%}
  {{ section.settings.heading_font | font_face: font_display: 'swap' }}
{%- endif -%}
{%- if section.settings.subheading_font != blank and section.settings.use_futura_subheading == false -%}
  {{ section.settings.subheading_font | font_face: font_display: 'swap' }}
{%- endif -%}
{%- if section.settings.product_title_font != blank and section.settings.use_futura_title == false -%}
  {{ section.settings.product_title_font | font_face: font_display: 'swap' }}
{%- endif -%}
{%- if section.settings.product_price_font != blank and section.settings.use_futura_price == false -%}
  {{ section.settings.product_price_font | font_face: font_display: 'swap' }}
{%- endif -%}

/* Main Heading Style */
#bss-{{ section.id }} .bss-heading {
  {%- if section.settings.use_futura_heading -%}
    font-family: 'FuturaCustom', sans-serif !important;
  {%- else -%}
    {%- if section.settings.heading_font != blank -%}
      font-family: {{ section.settings.heading_font.family }}, {{ section.settings.heading_font.fallback_families }} !important;
      font-weight: {{ section.settings.heading_font.weight }} !important;
      font-style: {{ section.settings.heading_font.style }} !important;
    {%- endif -%}
  {%- endif -%}
  
  /* BHAII YAHAN CLAMP HATAKAR DIRECT SIZE LAGAYA HAI (Ab 10px bhi kaam karega) */
  font-size: {{ section.settings.heading_size }}px !important;
  
  letter-spacing: {{ section.settings.heading_spacing }}px !important;
  color: {{ section.settings.heading_color }} !important;
}

/* Subheading Style */
#bss-{{ section.id }} .bss-subheading {
  {%- if section.settings.use_futura_subheading -%}
    font-family: 'FuturaCustom', sans-serif !important;
  {%- else -%}
    {%- if section.settings.subheading_font != blank -%}
      font-family: {{ section.settings.subheading_font.family }}, {{ section.settings.subheading_font.fallback_families }} !important;
      font-weight: {{ section.settings.subheading_font.weight }} !important;
      font-style: {{ section.settings.subheading_font.style }} !important;
    {%- endif -%}
  {%- endif -%}
  font-size: {{ section.settings.subheading_size }}px !important;
  color: {{ section.settings.text_color }} !important;
}

/* --- PRODUCT CARD TYPOGRAPHY --- */
/* Product Name */
#bss-{{ section.id }} .product-box .product-title,
#bss-{{ section.id }} .product-box .product-title a,
#bss-{{ section.id }} .product-box .product-name,
#bss-{{ section.id }} .product-box .product-name a {
  {%- if section.settings.use_futura_title -%}
    font-family: 'FuturaCustom', sans-serif !important;
  {%- else -%}
    {%- if section.settings.product_title_font != blank -%}
      font-family: {{ section.settings.product_title_font.family }}, {{ section.settings.product_title_font.fallback_families }} !important;
      font-weight: {{ section.settings.product_title_font.weight }} !important;
      font-style: {{ section.settings.product_title_font.style }} !important;
    {%- endif -%}
  {%- endif -%}
  font-size: {{ section.settings.product_title_size }}px !important;
  color: {{ section.settings.product_title_color }} !important;
}

/* Product Price */
#bss-{{ section.id }} .product-box .price,
#bss-{{ section.id }} .product-box .price-item,
#bss-{{ section.id }} .product-box .amount {
  {%- if section.settings.use_futura_price -%}
    font-family: 'FuturaCustom', sans-serif !important;
  {%- else -%}
    {%- if section.settings.product_price_font != blank -%}
      font-family: {{ section.settings.product_price_font.family }}, {{ section.settings.product_price_font.fallback_families }} !important;
      font-weight: {{ section.settings.product_price_font.weight }} !important;
      font-style: {{ section.settings.product_price_font.style }} !important;
    {%- endif -%}
  {%- endif -%}
  font-size: {{ section.settings.product_price_size }}px !important;
  color: {{ section.settings.product_price_color }} !important;
}

/* ================================================
  SHAPES & BORDERS
================================================ */
#bss-{{ section.id }} .bss-card,
#bss-{{ section.id }} .bss-card img,
#bss-{{ section.id }} .bss-card .product-image {
  border-radius: {{ section.settings.card_radius }}px !important;
  overflow: hidden;
}

#bss-{{ section.id }} .bss-arrow {
  border-radius: {{ section.settings.arrow_radius }}px !important;
}

/* ================================================
  BEST SELLER SLIDER CSS
================================================ */

#bss-{{ section.id }},
#bss-{{ section.id }} .bss-container,
#bss-{{ section.id }} .bss-header,
#bss-{{ section.id }} .bss-slider,
#bss-{{ section.id }} .bss-card {
  box-sizing: border-box;
}

#bss-{{ section.id }}.bss-section {
  position: relative;
  z-index: 1;
  width: 100%;
  overflow: hidden;
  padding: 58px 0 62px;
  background: {{ section.settings.bg }} !important;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

#bss-{{ section.id }}.bss-section::before,
#bss-{{ section.id }}.bss-section::after,
#bss-{{ section.id }} .bss-pattern {
  display: none !important;
}

#bss-{{ section.id }} .bss-container {
  position: relative;
  z-index: 1;
  width: calc(100% - 32px);
  max-width: 1240px;
  margin: 0 auto;
}

#bss-{{ section.id }} .bss-header {
  position: relative;
  text-align: center;
  margin: 0 0 10px;
}

#bss-{{ section.id }} .bss-header::after {
  content: "";
  display: block;
  width: 42px;
  height: 1px;
  margin: 16px auto 0;
  background: rgba(255, 255, 255, 0.42);
}

#bss-{{ section.id }} .bss-heading {
  margin: 0;
  line-height: 1.15;
  text-transform: uppercase;
  font-weight: 600 !important;
}

#bss-{{ section.id }} .bss-subheading {
  text-align: center;
  max-width: 560px;
  margin: 0 auto 28px;
  line-height: 1.6;
  opacity: 0.74;
}

#bss-{{ section.id }} .bss-slider {
  position: relative;
  padding: 0 6px;
}

#bss-{{ section.id }} .bss-viewport {
  width: 100%;
  overflow: hidden;
  padding: 0;
}

#bss-{{ section.id }} .bss-track {
  display: flex !important;
  flex-wrap: nowrap !important;
  gap: 18px;
  margin: 0 !important;
  align-items: stretch;
}

#bss-{{ section.id }} .bss-card {
  flex: 0 0 calc((100% - (18px * ({{ section.settings.desktop_show | minus: 1 }}))) / {{ section.settings.desktop_show }}) !important;
  max-width: calc((100% - (18px * ({{ section.settings.desktop_show | minus: 1 }}))) / {{ section.settings.desktop_show }}) !important;
  margin: 0 !important;
  padding: 8px !important;
  background: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 18px 38px rgba(0, 0, 0, 0.22);
}

#bss-{{ section.id }} .bss-card > div {
  height: 100%;
  margin-bottom: 0 !important;
}

#bss-{{ section.id }} .bss-card .product-image,
#bss-{{ section.id }} .bss-card .product-image > a,
#bss-{{ section.id }} .bss-card .product-image img,
#bss-{{ section.id }} .bss-card img {
  border-radius: {{ section.settings.card_radius }}px !important;
}

#bss-{{ section.id }} .bss-card .product-image img {
  display: block;
  width: 100%;
}

#bss-{{ section.id }} .product-box .product-title,
#bss-{{ section.id }} .product-box .product-title a,
#bss-{{ section.id }} .product-box .product-name,
#bss-{{ section.id }} .product-box .product-name a {
  line-height: 1.35 !important;
  letter-spacing: 0 !important;
}

#bss-{{ section.id }} .product-box .price,
#bss-{{ section.id }} .product-box .price-item,
#bss-{{ section.id }} .product-box .amount {
  line-height: 1.35 !important;
}

#bss-{{ section.id }} .bss-arrow {
  position: absolute;
  top: 43%;
  transform: translateY(-50%);
  z-index: 10;
  width: 40px;
  height: 40px;
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: {{ section.settings.arrow_radius }}px !important;
  background: rgba(10, 10, 12, 0.82);
  color: #ffffff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 14px 30px rgba(0, 0, 0, 0.28);
  transition: background 0.22s ease, border-color 0.22s ease, transform 0.22s ease;
}

#bss-{{ section.id }} .bss-arrow:hover {
  background: #ffffff;
  border-color: #ffffff;
  color: #050507;
  transform: translateY(-50%) scale(1.04);
}

#bss-{{ section.id }} .bss-arrow--prev { left: -10px; }
#bss-{{ section.id }} .bss-arrow--next { right: -10px; }

#bss-{{ section.id }} .bss-empty {
  width: 100%;
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
}

@media (max-width: 991px) {
  #bss-{{ section.id }}.bss-section {
    padding: 46px 0 50px;
  }

  #bss-{{ section.id }} .bss-container {
    width: calc(100% - 24px);
    max-width: 920px;
  }

  #bss-{{ section.id }} .bss-track {
    gap: 12px;
  }

  #bss-{{ section.id }} .bss-card {
    flex: 0 0 calc((100% - (12px * ({{ section.settings.mobile_show | minus: 1 }}))) / {{ section.settings.mobile_show }}) !important;
    max-width: calc((100% - (12px * ({{ section.settings.mobile_show | minus: 1 }}))) / {{ section.settings.mobile_show }}) !important;
    padding: 6px !important;
  }

  #bss-{{ section.id }} .bss-arrow--prev { left: -4px; }
  #bss-{{ section.id }} .bss-arrow--next { right: -4px; }
}

@media (max-width: 767px) {
  #bss-{{ section.id }}.bss-section {
    padding: 38px 0 42px;
  }

  #bss-{{ section.id }} .bss-header {
    margin-bottom: 8px;
  }

  #bss-{{ section.id }} .bss-header::after {
    margin-top: 12px;
  }

  #bss-{{ section.id }} .bss-subheading {
    margin-bottom: 22px;
    font-size: 13px !important;
  }

  #bss-{{ section.id }} .bss-slider {
    padding: 0;
  }

  #bss-{{ section.id }} .bss-arrow {
    display: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var root = document.getElementById('bss-{{ section.id }}');
  if (!root) return;

  var track = root.querySelector('.bss-track');
  var btnPrev = root.querySelector('.bss-arrow--prev');
  var btnNext = root.querySelector('.bss-arrow--next');
  
  if (!track || track.children.length === 0) return;

  var desktopCount = {{ section.settings.desktop_show | default: 4 }};
  var mobileCount = {{ section.settings.mobile_show | default: 2 }};
  
  var visible = window.innerWidth < 768 ? mobileCount : desktopCount;
  var gap = window.innerWidth <= 991 ? 12 : 18;
  var cardW = 0;

  function updateDimensions() {
    visible = window.innerWidth < 768 ? mobileCount : desktopCount;
    gap = window.innerWidth <= 991 ? 12 : 18;
    var viewportW = root.querySelector('.bss-viewport').offsetWidth;
    cardW = (viewportW - gap * (visible - 1)) / visible;
  }

  updateDimensions();
  window.addEventListener('resize', function() {
    setTimeout(updateDimensions, 100);
  });

  var isAnimating = false;

  function slideNext() {
    if (isAnimating) return;
    isAnimating = true;
    
    track.style.transition = 'transform 0.4s ease-in-out';
    track.style.transform = 'translateX(-' + (cardW + gap) + 'px)';

    setTimeout(function() {
      track.style.transition = 'none';
      track.appendChild(track.firstElementChild);
      track.style.transform = 'translateX(0)';
      isAnimating = false;
    }, 400);
  }

  function slidePrev() {
    if (isAnimating) return;
    isAnimating = true;

    track.style.transition = 'none';
    track.insertBefore(track.lastElementChild, track.firstElementChild);
    track.style.transform = 'translateX(-' + (cardW + gap) + 'px)';

    track.offsetHeight;

    track.style.transition = 'transform 0.4s ease-in-out';
    track.style.transform = 'translateX(0)';

    setTimeout(function() {
      isAnimating = false;
    }, 400);
  }

  if (btnNext) btnNext.addEventListener('click', function() { slideNext(); resetAuto(); });
  if (btnPrev) btnPrev.addEventListener('click', function() { slidePrev(); resetAuto(); });

  var touchX = 0;
  track.addEventListener('touchstart', function(e) {
    touchX = e.changedTouches[0].clientX;
  }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var diff = touchX - e.changedTouches[0].clientX;
    if (diff > 40) { slideNext(); resetAuto(); }
    if (diff < -40) { slidePrev(); resetAuto(); }
  });

  var autoplay = {{ section.settings.autoplay | json }};
  var speed = {{ section.settings.autoplay_speed | default: 3 | times: 1000 }};
  var autoTimer;

  function startAuto() {
    if (!autoplay) return;
    clearInterval(autoTimer);
    autoTimer = setInterval(slideNext, speed);
  }

  function stopAuto() { clearInterval(autoTimer); }
  function resetAuto() { stopAuto(); startAuto(); }

  startAuto();

  if ({{ section.settings.pause_hover | json }}) {
    root.addEventListener('mouseenter', stopAuto);
    root.addEventListener('mouseleave', startAuto);
  }
});
</script>

{% schema %}
{
  "name": "Best Seller Slider",
  "tag": "section",
  "class": "premium-best-seller",
  "settings": [
    {
      "type": "header",
      "content": "✨ Master Typography (Section)"
