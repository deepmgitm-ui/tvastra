<script>
  (function () {
    var popup = document.getElementById('tvastra-lead-popup');
    if (!popup) return;

    var submittedKey = 'tvastra_popup_submitted_v1';
    var firstDelay = 3000;
    var repeatDelay = 60000;

    if (localStorage.getItem(submittedKey) === 'yes') return;

    function showPopup() {
      if (localStorage.getItem(submittedKey) === 'yes') return;
      popup.hidden = false;
    }

    function hideAndRepeat() {
      popup.hidden = true;
      setTimeout(showPopup, repeatDelay);
    }

    setTimeout(showPopup, firstDelay);

    var closeBtn = popup.querySelector('.tv-lead-close');
    if (closeBtn) closeBtn.addEventListener('click', hideAndRepeat);

    var form = popup.querySelector('form');
    if (form) {
      form.addEventListener('submit', function () {
        localStorage.setItem(submittedKey, 'yes');
      });
    }
  })();
</script>
{% endunless %}



  </body>
</html>
