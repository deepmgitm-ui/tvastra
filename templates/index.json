    "custom_liquid_QQd9QU": {
      "type": "custom-liquid",
      "name": "custom Marque",
      "settings": {
        "container_type": "container",
        "custom_liquid": "<style>\n  .product-marquee-wrapper {\n    width: 100vw !important;\n    position: relative;\n    left: 50%;\n    right: 50%;\n    margin-left: -50vw !important;\n    margin-right: -50vw !important;\n  }\n  .product-marquee-box {\n    width: 100%;\n    overflow: hidden;\n    background-color: #f7f7f7; \n    padding: 8px 0; \n    margin: 0; \n    border-radius: 0; \n    box-sizing: border-box;\n    border-top: 1px solid #e5e5e5;\n    border-bottom: 1px solid #e5e5e5;\n    display: flex; \n  }\n  .product-marquee-inner {\n    display: flex;\n    flex-wrap: nowrap;\n    width: max-content; \n    /* Speed 30s set ki hai taaki aaram se padha ja sake */\n    animation: scrollMarquee 30s linear infinite; \n  }\n  .product-marquee-item {\n    display: flex;\n    align-items: center;\n    flex-shrink: 0; \n  }\n  .product-marquee-item span {\n    font-size: 13px;\n    font-weight: 400; /* Yaha 600 se 400 kar diya text ko slim karne ke liye */\n    color: #1a1a1a;\n    display: flex;\n    align-items: center;\n    gap: 8px; \n    white-space: nowrap;\n    margin: 0;\n    padding: 0 25px; \n  }\n  .product-marquee-item svg {\n    height: 16px; \n    width: 16px;\n    fill: none;\n    stroke: #1a1a1a;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    display: block;\n  }\n  \n  @keyframes scrollMarquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n</style>\n\n<div class=\"product-marquee-wrapper\">\n  <div class=\"product-marquee-box\">\n    <div class=\"product-marquee-inner\">\n      \n      <div class=\"product-marquee-item\">\n        <span><svg viewBox=\"0 0 24 24\"><rect x=\"2\" y=\"6\" width=\"20\" height=\"12\" rx=\"2\"></rect><circle cx=\"12\" cy=\"12\" r=\"2\"></circle><path d=\"M6 12h.01M18 12h.01\"></path></svg> Cash On Delivery</span>\n        <span><svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\"></rect><polygon points=\"16 8 20 8 23 11